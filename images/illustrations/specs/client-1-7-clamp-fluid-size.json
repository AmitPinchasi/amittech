{
  "title": "הפונקציה clamp שומרת גודל פונט בין מינימום למקסימום לפי רוחב המסך",
  "layout": { "type": "stack" },
  "components": [
    { "id": "rule", "type": "code", "label": "font-size: clamp(1.5rem, 4vw, 3rem)" },
    { "id": "vw", "type": "dynamic",
      "values": ["width = 300px, 4vw = 12px", "width = 800px, 4vw = 32px",
                 "width = 1600px, 4vw = 64px"] },
    { "id": "result", "type": "dynamic",
      "values": ["המינימום מנצח: font-size = 24px", "הערך המועדף: font-size = 32px",
                 "המקסימום מנצח: font-size = 48px"] },
    { "id": "note", "type": "text",
      "label": "כשהערך המועדף קטן מהמינימום או גדול מהמקסימום, הגבול הוא שקובע" }
  ],
  "connections": [],
  "animation": {
    "step_seconds": 2.4,
    "steps": [
      { "active": ["rule"] },
      { "active": ["vw", "result"] },
      { "active": ["vw", "result"], "set": { "vw": 1, "result": 1 } },
      { "active": ["vw", "result"], "set": { "vw": 2, "result": 2 } }
    ]
  }
}
