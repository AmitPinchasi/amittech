{
  "title": "תרשים זרימה של Web Worker: החישוב הכבד רץ בthread נפרד, הUI ממשיך להגיב, והתוצאה חוזרת בהודעה",
  "layout": { "type": "flow" },
  "components": [
    { "id": "ui", "type": "box", "label": "הthread הראשי (UI)",
      "values": ["הthread הראשי (UI)", "הUI ממשיך להגיב - לא נתקע"] },
    { "id": "post", "type": "code", "label": "worker.postMessage(data)" },
    { "id": "worker", "type": "box", "label": "הworker ממיין ברקע" },
    { "id": "result", "type": "code", "label": "postMessage(sorted)" },
    { "id": "update", "type": "box", "label": "עדכון הstate והרינדור" }
  ],
  "connections": [
    { "from": "ui", "to": "post" },
    { "from": "post", "to": "worker", "label": "לthread נפרד" },
    { "from": "worker", "to": "result", "label": "בסיום החישוב" },
    { "from": "result", "to": "update" }
  ],
  "animation": {
    "step_seconds": 1.5,
    "steps": [
      { "active": ["ui"], "set": { "ui": 0 } },
      { "active": ["post"], "edges": [0] },
      { "active": ["worker"], "edges": [1] },
      { "active": ["worker", "ui"], "set": { "ui": 1 } },
      { "active": ["result"], "edges": [2] },
      { "active": ["update"], "edges": [3] }
    ]
  }
}
