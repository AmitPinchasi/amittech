{
  "title": "פולימורפיזם בC: כל struct מחזיק מצביע לפונקציה משלו, ולכן אותה קריאה מגיעה לקוד אחר לכל מופע",
  "layout": { "type": "flow" },
  "components": [
    { "id": "call", "type": "code", "values": ["animals[0].speak(&animals[0]);", "animals[1].speak(&animals[1]);"] },
    { "id": "obj", "type": "box", "values": ["המופע Rex מסוג dog", "המופע Whiskers מסוג cat"] },
    { "id": "slot", "type": "code", "values": ["speak = dog_speak", "speak = cat_speak"] },
    { "id": "out", "type": "box", "values": ["Rex says: Woof!", "Whiskers says: Meow!"] },
    { "id": "note", "type": "text", "label": "הדפוס הזה הוא הבסיס לfile_operations בקרנל של לינוקס" }
  ],
  "connections": [
    { "from": "call", "to": "obj", "label": "קוראים דרך המופע" },
    { "from": "obj", "to": "slot", "label": "שולפים את המצביע" },
    { "from": "slot", "to": "out", "label": "קופצים לפונקציה" }
  ],
  "animation": {
    "step_seconds": 1.8,
    "steps": [
      { "active": ["call"], "set": { "call": 0, "obj": 0, "slot": 0, "out": 0 } },
      { "active": ["obj"], "edges": [0] },
      { "active": ["slot"], "edges": [1] },
      { "active": ["out"], "edges": [2] },
      { "active": ["call"], "set": { "call": 1, "obj": 1 } },
      { "active": ["slot"], "edges": [1], "set": { "slot": 1 } },
      { "active": ["out"], "edges": [2], "set": { "out": 1 } }
    ]
  }
}
