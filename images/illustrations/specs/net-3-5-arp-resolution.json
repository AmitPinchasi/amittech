{
  "title": "פרוטוקול ARP מגלה את כתובת ה-MAC של הראוטר: המחשב בודק את טבלת ה-ARP, שולח בקשת Broadcast, והראוטר עונה עם כתובת ה-MAC שלו",
  "layout": { "type": "flow" },
  "components": [
    { "id": "need", "type": "box", "label": "המחשב צריך את כתובת ה-MAC של הראוטר" },
    { "id": "cache", "type": "diamond", "label": "נמצא בטבלת ARP?" },
    { "id": "hit", "type": "box", "label": "נמצא - שולח מיד" },
    { "id": "req", "type": "dynamic", "values": ["ARP: Who has 192.168.1.1? Tell 192.168.1.10"] },
    { "id": "reply", "type": "dynamic", "values": ["הראוטר עונה עם כתובת ה-MAC שלו", "192.168.1.1 is at 00:1A:2B:3C:4D:5E"] },
    { "id": "done", "type": "box", "label": "עכשיו אפשר לשלוח את הפאקטה לראוטר" }
  ],
  "connections": [
    { "from": "need", "to": "cache" },
    { "from": "cache", "to": "hit", "label": "כן", "side": "right" },
    { "from": "cache", "to": "req", "label": "לא, שולח Broadcast" },
    { "from": "req", "to": "reply" },
    { "from": "reply", "to": "done" }
  ],
  "animation": {
    "step_seconds": 1.9,
    "steps": [
      { "active": ["need"] },
      { "active": ["cache"], "edges": [0] },
      { "active": ["req"], "edges": [2], "set": { "reply": 0 } },
      { "active": ["reply"], "edges": [3], "set": { "reply": 1 } },
      { "active": ["done"], "edges": [4] }
    ]
  }
}
