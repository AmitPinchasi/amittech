{
  "title": "סיבוב של לולאת אירועים: המתנה לאירוע, מציאת הcallback לפי המתאר, והרצתו עד לסיבוב הבא",
  "layout": { "type": "flow" },
  "components": [
    { "id": "run", "type": "diamond", "label": "loop->running" },
    { "id": "wait", "type": "box", "label": "המתנה לאירועים - epoll_wait",
      "values": [
        "המתנה לאירועים - epoll_wait",
        "הטיימר פקע, מתאר מספר 4 מוכן",
        "הוקלדה שורה, מתאר מספר 0 מוכן",
        "התקבל סיגנל, מתאר מספר 5 מוכן"
      ] },
    { "id": "disp", "type": "box", "label": "מציאת הcallback לפי המתאר" },
    { "id": "cb", "type": "box", "label": "הרצת הcallback",
      "values": [
        "הרצת הcallback",
        "הדפסת tick והמשך",
        "הדפסת השורה שהוקלדה",
        "עצירת הלולאה - event_loop_stop"
      ] },
    { "id": "done", "type": "box", "label": "סגירת המתארים ויציאה" }
  ],
  "connections": [
    { "from": "run", "to": "wait", "label": "כן" },
    { "from": "wait", "to": "disp" },
    { "from": "disp", "to": "cb" },
    { "from": "cb", "to": "run", "loop": true, "label": "הסיבוב הבא" },
    { "from": "run", "to": "done", "label": "לא", "side": "right" }
  ],
  "animation": {
    "step_seconds": 1.7,
    "steps": [
      { "active": ["run"], "set": { "wait": 0, "cb": 0 } },
      { "active": ["wait"], "edges": [0], "set": { "wait": 1 } },
      { "active": ["disp"], "edges": [1] },
      { "active": ["cb"], "edges": [2], "set": { "cb": 1 } },
      { "edges": [3] },
      { "active": ["wait"], "edges": [0], "set": { "wait": 2 } },
      { "active": ["cb"], "edges": [2], "set": { "cb": 2 } },
      { "edges": [3] },
      { "active": ["wait"], "edges": [0], "set": { "wait": 3 } },
      { "active": ["cb"], "edges": [2], "set": { "cb": 3 } },
      { "active": ["done"], "edges": [4] }
    ]
  }
}
