{
  "title": "שמירת אובייקט ב-localStorage: בלי JSON.stringify נשמרת מחרוזת חסרת תועלת, ועם stringify ו-parse האובייקט חוזר שלם",
  "layout": { "type": "flow" },
  "components": [
    { "id": "obj", "type": "code", "label": "let user = { name: \"Dan\", age: 25 }" },
    { "id": "save", "type": "code",
      "label": "localStorage.setItem(\"user\", user)",
      "values": [
        "localStorage.setItem(\"user\", user)",
        "localStorage.setItem(\"user\", JSON.stringify(user))"
      ] },
    { "id": "stored", "type": "box",
      "label": "\"[object Object]\"",
      "values": [
        "\"[object Object]\"",
        "{\"name\":\"Dan\",\"age\":25}"
      ] },
    { "id": "back", "type": "box",
      "label": "המידע אבד - אי אפשר לשחזר את האובייקט",
      "values": [
        "המידע אבד - אי אפשר לשחזר את האובייקט",
        "קריאה עם JSON.parse מחזירה את האובייקט"
      ] }
  ],
  "connections": [
    { "from": "obj", "to": "save" },
    { "from": "save", "to": "stored", "label": "מה שנשמר בפועל" },
    { "from": "stored", "to": "back" }
  ],
  "animation": {
    "step_seconds": 1.8,
    "steps": [
      { "active": ["obj"] },
      { "active": ["save"], "edges": [0] },
      { "active": ["stored"], "edges": [1] },
      { "active": ["back"], "edges": [2] },
      { "active": ["save"], "set": { "save": 1 } },
      { "active": ["stored"], "edges": [1], "set": { "stored": 1 } },
      { "active": ["back"], "edges": [2], "set": { "back": 1 } }
    ]
  }
}
