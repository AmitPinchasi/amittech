{
  "title": "בהעברת props הנתונים עוברים דרך כל קומפוננטה בשרשרת גם אם היא לא זקוקה להם, ואילו הקונטקסט מעביר אותם ישירות לקומפוננטה שצורכת אותם",
  "layout": { "type": "flow" },
  "components": [
    { "id": "prov", "type": "box", "label": "הספק UserProvider מחזיק את user" },
    { "id": "lay", "type": "box", "label": "הקומפוננטה Layout - רק מעבירה" },
    { "id": "hdr", "type": "box", "label": "הקומפוננטה Header - רק מעבירה" },
    { "id": "nav", "type": "box", "label": "הקומפוננטה Navigation - צורכת" }
  ],
  "connections": [
    { "from": "prov", "to": "lay", "label": "props: user" },
    { "from": "lay", "to": "hdr", "label": "props: user" },
    { "from": "hdr", "to": "nav", "label": "props: user" },
    { "from": "prov", "to": "nav", "label": "דרך הקונטקסט", "loop": true }
