{
  "title": "תהליך DHCP בו המחשב מקבל כתובת IP: שליחת Discover, קבלת Offer, שליחת Request ולבסוף Ack שמעניק את הכתובת",
  "layout": { "type": "flow" },
  "components": [
    { "id": "start", "type": "box", "label": "המחשב עולה ללא כתובת IP" },
    { "id": "discover", "type": "dynamic", "values": ["DHCP Discover (broadcast)"] },
    { "id": "offer", "type": "dynamic", "values": ["DHCP Offer: 192.168.1.10"] },
    { "id": "request", "type": "dynamic", "values": ["DHCP Request: 192.168.1.10"] },
    { "id": "ack", "type": "dynamic", "values": ["DHCP Ack: lease granted"] },
    { "id": "done", "type": "box", "values": ["אין עדיין כתובת IP", "כתובת IP: 192.168.1.10"] }
  ],
  "connections": [
    { "from": "start", "to": "discover" },
    { "from": "discover", "to": "offer", "label": "השרת מציע" },
    { "from": "offer", "to": "request", "label": "המחשב מבקש" },
    { "from": "request", "to": "ack", "label": "השרת מאשר" },
    { "from": "ack", "to": "done" }
  ],
  "animation": {
    "step_seconds": 1.8,
    "steps": [
      { "active": ["start"], "set": { "done": 0 } },
      { "active": ["discover"], "edges": [0] },
      { "active": ["offer"], "edges": [1] },
      { "active": ["request"], "edges": [2] },
      { "active": ["ack"], "edges": [3] },
      { "active": ["done"], "edges": [4], "set": { "done": 1 } }
    ]
  }
}
