{
  "title": "תרשים המראה את המסלול של הפקודה int 0x80 מקוד היוזר מוד אל השער בטבלת ה-IDT, אל קוד הקרנל וחזרה",
  "layout": { "type": "flow" },
  "components": [
    { "id": "user", "type": "code", "lines": ["mov eax, 4", "mov ebx, msg", "int 0x80"] },
    { "id": "lookup", "type": "box", "label": "המעבד ניגש לשורה מספר 0x80 בטבלת ה-IDT" },
    { "id": "gate", "type": "code", "lines": ["Offset   = kernel_dispatcher", "Selector = 0x08", "DPL      = 3"] },
    { "id": "switch", "type": "box", "label": "המעבד טוען את cs ואת eip מהשער ועובר להרשאות קרנל" },
    { "id": "kernel", "type": "code", "lines": ["kernel_dispatcher:", "cmp eax, 4", "je print_text"] },
    { "id": "iret", "type": "code", "label": "iret" },
    { "id": "back", "type": "box", "label": "התוכנה ממשיכה מהשורה שאחרי הפקודה int" },
    { "id": "ring", "type": "dynamic", "values": ["ring = 3", "ring = 0", "ring = 3"] }
  ],
  "connections": [
    { "from": "user", "to": "lookup" },
    { "from": "lookup", "to": "gate" },
    { "from": "gate", "to": "switch" },
    { "from": "switch", "to": "kernel" },
    { "from": "kernel", "to": "iret" },
    { "from": "iret", "to": "back" }
  ],
  "animation": {
    "step_seconds": 1.8,
    "steps": [
      { "active": ["user"], "set": { "ring": 0 } },
      { "active": ["lookup"], "edges": [0] },
      { "active": ["gate"], "edges": [1] },
      { "active": ["switch"], "edges": [2], "set": { "ring": 1 } },
      { "active": ["kernel"], "edges": [3] },
      { "active": ["iret"], "edges": [4] },
      { "active": ["back"], "edges": [5], "set": { "ring": 2 } }
    ]
  }
}
