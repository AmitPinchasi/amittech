{
  "title": "מחזור החיים של אלמנט יוצא עם AnimatePresence לעומת הסרה רגילה מה-DOM",
  "layout": { "type": "flow" },
  "components": [
    { "id": "state", "type": "box", "label": "הקומפוננטה מוסרת מה-state" },
    { "id": "cond", "type": "diamond", "label": "עטופה ב-AnimatePresence?" },
    { "id": "gone", "type": "box", "label": "נעלמת מיד בלי אנימציה" },
    { "id": "keep", "type": "box", "label": "האלמנט נשאר ב-DOM זמנית" },
    { "id": "exit", "type": "code", "label": "exit={{ opacity: 0, x: 100 }}" },
    { "id": "remove", "type": "box", "label": "בסיום האנימציה האלמנט מוסר" }
  ],
  "connections": [
    { "from": "state", "to": "cond" },
    { "from": "cond", "to": "gone", "label": "לא", "side": "right" },
    { "from": "cond", "to": "keep", "label": "כן" },
    { "from": "keep", "to": "exit" },
    { "from": "exit", "to": "remove" }
  ],
  "animation": {
    "step_seconds": 1.8,
    "steps": [
      { "active": ["state"] },
      { "active": ["cond"], "edges": [0] },
      { "active": ["keep"], "edges": [2] },
      { "active": ["exit"], "edges": [3] },
      { "active": ["remove"], "edges": [4] }
    ]
  }
}
