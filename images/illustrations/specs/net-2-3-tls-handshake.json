{
  "title": "לחיצת יד TLS: הלקוח והשרת מחליפים hello ותעודה, מאמתים מול ה-CA ובונים מפתח סשן משותף",
  "layout": { "type": "flow" },
  "components": [
    { "id": "hello", "type": "box", "label": "Client Hello" },
    { "id": "srvhello", "type": "box", "label": "Server Hello + Certificate" },
    { "id": "verify", "type": "box", "label": "הלקוח מאמת את התעודה מול ה-CA" },
    { "id": "keyexch", "type": "box", "label": "Key Exchange" },
    { "id": "key", "type": "dynamic", "values": ["אין עדיין מפתח משותף", "מפתח סשן משותף נוצר"] },
    { "id": "done", "type": "box", "label": "תקשורת מוצפנת (HTTPS)" }
  ],
  "connections": [
    { "from": "hello", "to": "srvhello" },
    { "from": "srvhello", "to": "verify" },
    { "from": "verify", "to": "keyexch" },
    { "from": "keyexch", "to": "key" },
    { "from": "key", "to": "done" }
  ],
  "animation": {
    "step_seconds": 1.6,
    "steps": [
      { "active": ["hello"] },
      { "active": ["srvhello"], "edges": [0] },
      { "active": ["verify"], "edges": [1] },
      { "active": ["keyexch"], "edges": [2] },
      { "active": ["key"], "edges": [3], "set": { "key": 1 } },
      { "active": ["done"], "edges": [4] }
    ]
  }
}
