{
  "title": "הagent מריץ בדיקות, רואה שלוש נכשלות, מתקן, ומריץ שוב עד שכולן עוברות",
  "layout": { "type": "flow" },
  "components": [
    { "id": "run", "type": "box", "label": "מריצים את הבדיקות" },
    { "id": "result", "type": "box", "label": "נכשלו: 3", "values": ["נכשלו: 3", "נכשלו: 0"] },
    { "id": "pass", "type": "diamond", "label": "עוברות?" },
    { "id": "fix", "type": "box", "label": "קוראים שגיאה ומתקנים" },
    { "id": "done", "type": "box", "label": "סיום - הכל עובר" }
  ],
  "connections": [
    { "from": "run", "to": "result" },
    { "from": "result", "to": "pass" },
    { "from": "pass", "to": "fix", "label": "לא", "side": "right" },
    { "from": "fix", "to": "run", "loop": true },
    { "from": "pass", "to": "done", "label": "כן" }
  ],
  "animation": {
    "step_seconds": 1.6,
    "steps": [
      { "active": ["run"], "edges": [0] },
      { "active": ["result"], "set": { "result": 0 } },
      { "active": ["pass"], "edges": [1] },
      { "active": ["fix"], "edges": [2] },
      { "active": ["run"], "edges": [3] },
      { "active": ["result"], "set": { "result": 1 } },
      { "active": ["pass"], "edges": [1] },
      { "active": ["done"], "edges": [4] }
    ]
  }
}
