{
  "title": "הcontext window הוא כל מה שהמודל רואה כרגע - הprompt, ההודעות, תשובות קודמות, קוד ופלט פקודות - והוא מתמלא בטוקנים עד גבול מקסימלי",
  "layout": { "type": "stack" },
  "components": [
    { "id": "win", "type": "table", "cells": ["הprompt", "הודעות", "תשובות", "קוד", "פלט"] },
    { "id": "count", "type": "dynamic", "values": ["10K / 200K", "100K / 200K", "195K / 200K"] },
    { "id": "note", "type": "text", "label": "ככל שהחלון מתמלא איכות התשובה עלולה לרדת" }
  ],
  "connections": [
    { "from": "win", "to": "count", "label": "טוקנים בשימוש" }
  ],
  "animation": {
    "step_seconds": 1.6,
    "steps": [
      { "active": ["win.0"], "set": { "count": 0 } },
      { "active": ["win.1"] },
      { "active": ["win.2"], "set": { "count": 1 } },
      { "active": ["win.3"] },
      { "active": ["win.4"], "set": { "count": 2 } }
    ]
  }
}
