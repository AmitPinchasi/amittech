{
  "title": "כיצד השרת מגיש דף PHP: הדפדפן מבקש קובץ, השרת מריץ את הקוד, קוד ה-PHP הופך ל-HTML ורק הוא חוזר ללקוח",
  "layout": { "type": "flow" },
  "components": [
    { "id": "req", "type": "code", "label": "GET /index.php" },
    { "id": "run", "type": "box", "label": "השרת מריץ את קוד ה-PHP" },
    { "id": "result", "type": "dynamic",
      "values": ["<?php echo date('d/m/Y'); ?>", "20/07/2026"] },
    { "id": "resp", "type": "box", "label": "רק ה-HTML הסופי חוזר ללקוח" },
    { "id": "browser", "type": "box", "label": "הדפדפן מציג את התוצאה" }
  ],
  "connections": [
    { "from": "req", "to": "run", "label": "בקשה מהדפדפן" },
    { "from": "run", "to": "result", "label": "הרצת הקוד" },
    { "from": "result", "to": "resp" },
    { "from": "resp", "to": "browser" }
  ],
  "animation": {
    "step_seconds": 1.8,
    "steps": [
      { "active": ["req"] },
      { "active": ["run"], "edges": [0] },
      { "active": ["result"], "edges": [1], "set": { "result": 0 } },
      { "active": ["result"], "set": { "result": 1 } },
      { "active": ["resp"], "edges": [2] },
      { "active": ["browser"], "edges": [3] }
    ]
  }
}
