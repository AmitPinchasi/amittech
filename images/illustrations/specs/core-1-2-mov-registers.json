{
  "title": "אנימציה של פקודות mov ו-add: הערכים ברגיסטרים ax ו-bx משתנים הוראה אחרי הוראה",
  "layout": { "type": "stack" },
  "components": [
    { "id": "code", "type": "code", "lines": ["mov ax, 5", "mov bx, ax", "add ax, 10"] },
    { "id": "step", "type": "box", "values": [
      "מכניסים את המספר 5 לרגיסטר ax",
      "מעתיקים את הערך של ax לרגיסטר bx",
      "מוסיפים 10 לערך שנמצא ב-ax"
    ] },
    { "id": "ax", "type": "dynamic", "values": ["AX = 0", "AX = 5", "AX = 15"] },
    { "id": "bx", "type": "dynamic", "values": ["BX = 0", "BX = 5"] },
    { "id": "note", "type": "text", "label": "הפקודה mov מעתיקה ערך ולא מוחקת את המקור" }
  ],
  "animation": {
    "step_seconds": 1.8,
    "steps": [
      { "active": ["ax", "bx"] },
      { "active": ["ax"], "set": { "step": 0, "ax": 1 } },
      { "active": ["bx"], "set": { "step": 1, "bx": 1 } },
      { "active": ["ax"], "set": { "step": 2, "ax": 2 } }
    ]
  }
}
