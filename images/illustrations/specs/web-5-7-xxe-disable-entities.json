{
  "title": "מנגנון XXE מול הגנת חסימת ישויות חיצוניות: כיצד פרסר XML שטוען entity מסוג file מחזיר את תוכן etc passwd, וכיצד חסימת ישויות חיצוניות בפרסר מונעת זאת",
  "layout": { "type": "flow" },
  "components": [
    {
      "id": "input",
      "type": "code",
      "lines": [
        "<!ENTITY file SYSTEM \"file:///etc/passwd\">",
        "<data>&file;</data>"
      ]
    },
    { "id": "check", "type": "diamond", "label": "ישויות חיצוניות חסומות?" },
    { "id": "resolve", "type": "box", "label": "הפרסר טוען את file ומחליף בתוכן הקובץ" },
    { "id": "leak", "type": "box", "label": "תוכן etc/passwd חוזר בתגובת ה-XML" },
    { "id": "safe", "type": "box", "label": "ישויות חיצוניות מבוטלות - אין דליפה" }
  ],
  "connections": [
    { "from": "input", "to": "check" },
    { "from": "check", "to": "resolve", "label": "לא" },
    { "from": "resolve", "to": "leak" },
    { "from": "check", "to": "safe", "label": "כן", "side": "right" }
  ],
  "animation": {
    "step_seconds": 1.7,
    "steps": [
      { "active": ["input"] },
      { "active": ["check"], "edges": [0] },
      { "active": ["safe"], "edges": [3] },
      { "active": ["check"] },
      { "active": ["resolve"], "edges": [1] },
      { "active": ["leak"], "edges": [2] }
    ]
  }
}
