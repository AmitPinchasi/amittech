{
  "title": "לולאת ReAct של סוכן AI: הסוכן חושב על הצעד הבא, מפעיל כלי, קורא את התוצאה ובודק אם המטרה הושגה - אם לא הוא חוזר לחשיבה, ואם כן מחזיר תשובה סופית",
  "layout": { "type": "flow" },
  "components": [
    { "id": "goal", "type": "box", "label": "מטרה - Goal" },
    { "id": "think", "type": "box", "label": "חשיבה - מה הצעד הבא?" },
    { "id": "act", "type": "box", "label": "פעולה - הפעלת כלי",
      "values": ["פעולה - חיפוש מלונות", "פעולה - שמירה ל-DB"] },
    { "id": "observe", "type": "box", "label": "צפייה - קריאת התוצאה",
      "values": ["צפייה - התקבלו מלונות", "צפייה - נשמר בהצלחה"] },
    { "id": "done", "type": "diamond", "label": "המטרה הושגה?" },
    { "id": "answer", "type": "box", "label": "החזרת תשובה סופית" }
  ],
  "connections": [
    { "from": "goal", "to": "think" },
    { "from": "think", "to": "act" },
    { "from": "act", "to": "observe" },
    { "from": "observe", "to": "done" },
    { "from": "done", "to": "think", "label": "לא", "loop": true },
    { "from": "done", "to": "answer", "label": "כן", "side": "right" }
  ],
  "animation": {
    "step_seconds": 1.7,
    "steps": [
      { "active": ["goal"], "set": { "act": 0, "observe": 0 } },
      { "active": ["think"], "edges": [0] },
      { "active": ["act"], "edges": [1], "set": { "act": 0 } },
      { "active": ["observe"], "edges": [2], "set": { "observe": 0 } },
      { "active": ["done"], "edges": [3] },
      { "active": ["think"], "edges": [4] },
      { "active": ["act"], "edges": [1], "set": { "act": 1 } },
      { "active": ["observe"], "edges": [2], "set": { "observe": 1 } },
      { "active": ["done"], "edges": [3] },
      { "active": ["answer"], "edges": [5] }
    ]
  }
}
