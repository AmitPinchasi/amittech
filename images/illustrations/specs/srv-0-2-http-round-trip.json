{
  "title": "מסלול בקשת HTTP: הדפדפן שולח בקשת GET, השרת מכין את העמוד ומחזיר תשובה עם קוד סטטוס, והדפדפן מציג אותו",
  "layout": { "type": "flow" },
  "components": [
    { "id": "browser", "type": "box", "label": "הדפדפן שולח בקשה",
      "values": ["הדפדפן שולח בקשה", "הדפדפן ממתין לתשובה", "הדפדפן מציג את העמוד"] },
    { "id": "req", "type": "code", "label": "GET /index.html" },
    { "id": "server", "type": "box", "label": "השרת מחפש ומכין את העמוד" },
    { "id": "resp", "type": "code", "label": "HTTP/1.1 200 OK" }
  ],
  "connections": [
    { "from": "browser", "to": "req", "label": "שולח בקשה" },
    { "from": "req", "to": "server", "label": "הבקשה מגיעה לשרת" },
    { "from": "server", "to": "resp" },
    { "from": "resp", "to": "browser", "loop": true, "label": "התשובה חוזרת" }
  ],
  "animation": {
    "step_seconds": 1.8,
    "steps": [
      { "active": ["browser"], "set": { "browser": 0 } },
      { "active": ["req"], "edges": [0], "set": { "browser": 1 } },
      { "active": ["server"], "edges": [1] },
      { "active": ["resp"], "edges": [2] },
      { "active": ["browser"], "edges": [3], "set": { "browser": 2 } }
    ]
  }
}
