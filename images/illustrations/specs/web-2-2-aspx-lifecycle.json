{
  "title": "כיצד ASP.NET מגיש דף: הדפדפן מבקש קובץ ASPX, השרת מריץ את Page_Load בקוד ה-C# שמעדכן את טקסט הרכיב, ורק ה-HTML הסופי חוזר ללקוח",
  "layout": { "type": "flow" },
  "components": [
    { "id": "req", "type": "code", "label": "GET /Default.aspx" },
    { "id": "proc", "type": "box", "label": "השרת מעבד את דף ה-ASPX" },
    { "id": "load", "type": "box", "label": "Page_Load רץ בצד השרת" },
    { "id": "label", "type": "dynamic",
      "values": ["lblMessage = 'Hello World!'", "lblMessage = 'Welcome to ASP.NET!'"] },
    { "id": "html", "type": "box", "label": "הרכיבים הופכים ל-HTML" },
    { "id": "browser", "type": "box", "label": "הדפדפן מציג את הדף" }
  ],
  "connections": [
    { "from": "req", "to": "proc", "label": "בקשה מהדפדפן" },
    { "from": "proc", "to": "load" },
    { "from": "load", "to": "label", "label": "הקוד מעדכן טקסט" },
    { "from": "label", "to": "html" },
    { "from": "html", "to": "browser" }
  ],
  "animation": {
    "step_seconds": 1.8,
    "steps": [
      { "active": ["req"] },
      { "active": ["proc"], "edges": [0] },
      { "active": ["load"], "edges": [1] },
      { "active": ["label"], "edges": [2], "set": { "label": 0 } },
      { "active": ["label"], "set": { "label": 1 } },
      { "active": ["html"], "edges": [3] },
      { "active": ["browser"], "edges": [4] }
    ]
  }
}
