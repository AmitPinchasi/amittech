{
  "title": "חילופי HTTP: הדפדפן שולח בקשת GET, השרת מחזיר סטטוס 200 והדפדפן מרנדר את הדף",
  "layout": { "type": "flow" },
  "components": [
    { "id": "client", "type": "box", "label": "דפדפן (Client)" },
    { "id": "req", "type": "code", "lines": ["GET /index.html HTTP/1.1", "Host: www.example.com"] },
    { "id": "server", "type": "box", "label": "שרת HTTP (Server)" },
    { "id": "resp", "type": "dynamic", "values": ["הסטטוס עדיין לא חזר", "HTTP/1.1 200 OK"] },
    { "id": "render", "type": "box", "label": "הדפדפן מרנדר את ה-HTML" }
  ],
  "connections": [
    { "from": "client", "to": "req", "label": "שולח בקשה" },
    { "from": "req", "to": "server" },
    { "from": "server", "to": "resp", "label": "מחזיר תשובה" },
    { "from": "resp", "to": "render" }
  ],
  "animation": {
    "step_seconds": 1.6,
    "steps": [
      { "active": ["client"] },
      { "active": ["req"], "edges": [0] },
      { "active": ["server"], "edges": [1] },
      { "active": ["resp"], "edges": [2], "set": { "resp": 1 } },
      { "active": ["render"], "edges": [3] }
    ]
  }
}
