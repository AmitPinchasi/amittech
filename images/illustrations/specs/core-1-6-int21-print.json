{
  "title": "אנימציה של הדפסת מחרוזת עם הפסיקה 21h: הרגיסטר dx מקבל את כתובת המחרוזת, ah בוחר את השירות, והפסיקה מדפיסה",
  "layout": { "type": "stack" },
  "components": [
    { "id": "instr", "type": "code", "values": ["mov dx, offset msg", "mov ah, 09h", "int 21h"] },
    { "id": "regs", "type": "dynamic", "values": [
      "AH = ?, DX = ?",
      "DX = offset msg",
      "AH = 09h, DX = offset msg"
    ] },
    { "id": "note", "type": "box", "values": [
      "טוענים ל-dx את הכתובת של המחרוזת",
      "הערך ב-ah בוחר את השירות הרצוי",
      "הפסיקה מריצה את השירות של מערכת ההפעלה"
    ] },
    { "id": "screen", "type": "dynamic", "values": ["המסך ריק", "Hello World!"] },
    { "id": "cap", "type": "text", "label": "המחרוזת חייבת להסתיים בסימן דולר כדי שהשירות ידע היכן לעצור" }
  ],
  "animation": {
    "step_seconds": 1.8,
    "steps": [
      { "active": ["regs"] },
      { "active": ["instr", "regs"], "set": { "instr": 0, "regs": 1, "note": 0 } },
      { "active": ["instr", "regs"], "set": { "instr": 1, "regs": 2, "note": 1 } },
      { "active": ["instr"], "set": { "instr": 2, "note": 2 } },
      { "active": ["screen"], "set": { "screen": 1 } }
    ]
  }
}
