{
  "title": "אוגר מצביע ההוראה מתקדם על סגמנט הקוד בזכרון ועוצר כשהוא מגיע לסגמנט הנתונים",
  "layout": { "type": "stack" },
  "components": [
    { "id": "ram", "type": "table", "cells": ["MOV", "MOV", "ADD", "MOV", "OUT", "DATA"] },
    { "id": "ip", "type": "dynamic", "values": ["IP = 1", "IP = 2", "IP = 3", "IP = 4", "IP = 5", "IP = 6"] },
    { "id": "state", "type": "box", "values": ["המעבד מריץ את ההוראה", "המעבד עוצר - הגענו לסגמנט הנתונים"] },
    { "id": "note", "type": "text", "label": "כתובות 1 עד 5 הן סגמנט הקוד, וכתובת 6 היא תחילת סגמנט הנתונים" }
  ],
  "connections": [
    { "from": "ram.0", "to": "ip" }
  ],
  "animation": {
    "step_seconds": 1.6,
    "steps": [
      { "active": ["ram.0"], "move": { "0": "ram.0" }, "set": { "ip": 0, "state": 0 } },
      { "active": ["ram.1"], "move": { "0": "ram.1" }, "set": { "ip": 1 } },
      { "active": ["ram.2"], "move": { "0": "ram.2" }, "set": { "ip": 2 } },
      { "active": ["ram.3"], "move": { "0": "ram.3" }, "set": { "ip": 3 } },
      { "active": ["ram.4"], "move": { "0": "ram.4" }, "set": { "ip": 4 } },
      { "active": ["ram.5", "state"], "move": { "0": "ram.5" }, "set": { "ip": 5, "state": 1 } }
    ]
  }
}
