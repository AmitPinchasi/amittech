{
  "title": "תרשים זרימה של לולאת for ב-PowerShell: המשתנה i מתחיל ב-1, התנאי -le נבדק בכל סיבוב, והמשתנה עולה עד שהתנאי נכשל",
  "layout": { "type": "flow" },
  "components": [
    { "id": "init", "type": "code", "label": "$i = 1" },
    { "id": "cond", "type": "diamond", "label": "$i -le 5",
      "values": ["$i -le 5", "1 -le 5", "2 -le 5", "3 -le 5", "4 -le 5", "5 -le 5", "6 -le 5"] },
    { "id": "body", "type": "code", "label": "Write-Output \"iteration $i\"" },
    { "id": "update", "type": "code", "label": "$i++",
      "values": ["$i++", "$i = 2", "$i = 3", "$i = 4", "$i = 5", "$i = 6"] },
    { "id": "end", "type": "box", "label": "סוף הלולאה" }
  ],
  "connections": [
    { "from": "init", "to": "cond" },
    { "from": "cond", "to": "body", "label": "אמת" },
    { "from": "body", "to": "update" },
    { "from": "update", "to": "cond", "loop": true, "label": "חזרה לבדיקה" },
    { "from": "cond", "to": "end", "label": "שקר", "side": "right" }
  ],
  "animation": {
    "step_seconds": 1.5,
    "steps": [
      { "active": ["init"] },
      { "active": ["cond"], "set": { "cond": 1 }, "edges": [0] },
      { "active": ["body"], "edges": [1] },
      { "active": ["update"], "set": { "update": 1 }, "edges": [2] },
      { "edges": [3] },
      { "active": ["cond"], "set": { "cond": 2 } },
      { "active": ["body"], "edges": [1] },
      { "active": ["update"], "set": { "update": 2 }, "edges": [2] },
      { "edges": [3] },
      { "active": ["cond"], "set": { "cond": 3 } },
      { "active": ["body"], "edges": [1] },
      { "active": ["update"], "set": { "update": 3 }, "edges": [2] },
      { "edges": [3] },
      { "active": ["cond"], "set": { "cond": 4 } },
      { "active": ["body"], "edges": [1] },
      { "active": ["update"], "set": { "update": 4 }, "edges": [2] },
      { "edges": [3] },
      { "active": ["cond"], "set": { "cond": 5 } },
      { "active": ["body"], "edges": [1] },
      { "active": ["update"], "set": { "update": 5 }, "edges": [2] },
      { "edges": [3] },
      { "active": ["cond"], "set": { "cond": 6 } },
      { "active": ["end"], "edges": [4] }
    ]
  }
}
