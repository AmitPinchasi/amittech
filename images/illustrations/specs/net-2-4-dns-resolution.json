{
  "title": "מסע שאילתת DNS: ה-resolver מטפס מ-Root ל-TLD ל-Authoritative עד שכתובת ה-IP מתגלה",
  "layout": { "type": "flow" },
  "components": [
    { "id": "client", "type": "box", "label": "הלקוח מבקש www.google.com" },
    { "id": "resolver", "type": "box", "label": "Recursive Resolver" },
    { "id": "root", "type": "box", "label": "Root Server ." },
    { "id": "tld", "type": "box", "label": "TLD Server com." },
    { "id": "auth", "type": "box", "label": "Authoritative google.com" },
    { "id": "answer", "type": "dynamic", "values": ["ה-IP עדיין לא ידוע", "ה-IP: 172.217.16.196"] }
  ],
  "connections": [
    { "from": "client", "to": "resolver" },
    { "from": "resolver", "to": "root", "label": "מי מנהל com.?" },
    { "from": "root", "to": "tld", "label": "פנה ל-TLD" },
    { "from": "tld", "to": "auth", "label": "פנה ל-google.com" },
    { "from": "auth", "to": "answer", "label": "ה-IP הוא" }
  ],
  "animation": {
    "step_seconds": 1.6,
    "steps": [
      { "active": ["client"] },
      { "active": ["resolver"], "edges": [0] },
      { "active": ["root"], "edges": [1] },
      { "active": ["tld"], "edges": [2] },
      { "active": ["auth"], "edges": [3] },
      { "active": ["answer"], "edges": [4], "set": { "answer": 1 } }
    ]
  }
}
