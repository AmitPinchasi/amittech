{
  "title": "סטרימינג של דשבורד עם Suspense שבו כל חלק בדף מגיע לדפדפן ברגע שהוא מוכן",
  "layout": { "type": "flow" },
  "components": [
    { "id": "req", "type": "box", "label": "בקשה לדף הדשבורד" },
    { "id": "shell", "type": "box", "label": "שלד הדף נשלח מיד עם ה-fallback" },
    { "id": "s1", "type": "box", "label": "Stats מסיים לשלוף ונשלח" },
    { "id": "s2", "type": "box", "label": "RevenueChart מסיים ונשלח" },
    { "id": "s3", "type": "box", "label": "LatestOrders מסיים ונשלח" },
    { "id": "screen", "type": "dynamic",
      "values": ["המשתמש רואה שלושה שלדים", "המשתמש רואה את הסטטיסטיקות", "נוסף גם הגרף", "הדף שלם"] }
  ],
  "connections": [
    { "from": "req", "to": "shell" },
    { "from": "shell", "to": "s1" },
    { "from": "s1", "to": "s2" },
    { "from": "s2", "to": "s3" },
    { "from": "s3", "to": "screen" }
  ],
  "animation": {
    "step_seconds": 1.8,
    "steps": [
      { "active": ["req"] },
      { "active": ["shell", "screen"], "set": { "screen": 0 }, "edges": [0] },
      { "active": ["s1", "screen"], "set": { "screen": 1 }, "edges": [1] },
      { "active": ["s2", "screen"], "set": { "screen": 2 }, "edges": [2] },
      { "active": ["s3", "screen"], "set": { "screen": 3 }, "edges": [3, 4] }
    ]
  }
}
