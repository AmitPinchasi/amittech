{
  "title": "טינול SSH מסוג local port forwarding: פאקטה שנשלחת לפורט מקומי 50 עוברת מוצפנת דרך שרת ה-SSH ומגיעה אל 8.8.8.8 בפורט 53",
  "layout": { "type": "flow" },
  "components": [
    { "id": "cmd", "type": "code", "label": "ssh -L 50:8.8.8.8:53 amitp@server" },
    { "id": "app", "type": "box", "label": "אפליקציה שולחת ל-localhost:50" },
    { "id": "ssh", "type": "box", "label": "לקוח ה-SSH מצפין ומעביר במנהרה" },
    { "id": "srv", "type": "box", "label": "שרת ה-SSH מפענח את התעבורה" },
    { "id": "dest", "type": "dynamic", "values": ["8.8.8.8:53 (DNS)"] }
  ],
  "connections": [
    { "from": "cmd", "to": "app" },
    { "from": "app", "to": "ssh", "label": "פורט 50" },
    { "from": "ssh", "to": "srv", "label": "מנהרה מוצפנת" },
    { "from": "srv", "to": "dest", "label": "מעביר ליעד" }
  ],
  "animation": {
    "step_seconds": 1.9,
    "steps": [
      { "active": ["cmd"] },
      { "active": ["app"], "edges": [0] },
      { "active": ["ssh"], "edges": [1] },
      { "active": ["srv"], "edges": [2] },
      { "active": ["dest"], "edges": [3] }
    ]
  }
}
