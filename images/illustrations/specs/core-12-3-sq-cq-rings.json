{
  "title": "מחזור בקשה בio_uring: הבקשה נכתבת לטבעת ההגשה והתוצאה מוחזרת דרך טבעת ההשלמה",
  "layout": { "type": "stack" },
  "components": [
    { "id": "app", "type": "code", "values": [
      "sqe = io_uring_get_sqe(&ring);",
      "io_uring_prep_read(sqe, fd, buf, 1024, 0);",
      "io_uring_submit(&ring);",
      "io_uring_wait_cqe(&ring, &cqe);",
      "cqe->res = 512; io_uring_cqe_seen(&ring, cqe);"
