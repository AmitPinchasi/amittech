    { "id": "sq", "type": "dynamic", "values": [
      "SQ = []",
      "SQ = [read fd=7 len=1024]",
      "SQ = []"
    ] },
    { "id": "cq", "type": "dynamic", "values": [
      "CQ = []",
      "CQ = [res=512 user_data=ctx]",
      "CQ = []"
    ] },
    { "id": "note", "type": "box", "values": [
      "התוכנה לוקחת רשומת הגשה פנויה מטבעת ההגשה המשותפת",
      "פרטי הפעולה נכתבים לרשומה: סוג הפעולה, המתאר, הבאפר, והאורך",
      "ההגשה מודיעה לקרנל שיש בקשות חדשות, ובמצב SQPOLL גם זה מיותר",
      "הקרנל מבצע את הפעולה וכותב את התוצאה לטבעת ההשלמה",
      "התוכנה קוראת את התוצאה מהזיכרון המשותף בלי קריאת מערכת נוספת"
    ] },
    { "id": "cap", "type": "text", "label": "שתי הטבעות ממופות בזיכרון בין התוכנה לקרנל, ולכן העברת הבקשות והתוצאות לא עולה קריאת מערכת" }
  ],
  "connections": [],
