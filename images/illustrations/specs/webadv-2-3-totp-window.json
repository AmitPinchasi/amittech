{
  "title": "חלון הזמן של TOTP: כשהשרת מקבל גם את החלון הקודם והבא, שלושה קודים תקפים בו-זמנית ומרחיבים את שטח התקיפה",
  "layout": { "type": "stack" },
  "components": [
    { "id": "verify", "type": "code", "label": "totp.verify(code, valid_window=1)" },
    { "id": "win", "type": "table", "cells": ["-2", "-1", "0", "+1", "+2"] },
    { "id": "st", "type": "dynamic", "values": ["מחוץ לחלון - נדחה", "בתוך החלון - מתקבל", "הקוד הנוכחי - מתקבל", "בתוך החלון - מתקבל", "מחוץ לחלון - נדחה", "שלושה קודים תקפים יחד"] },
    { "id": "note", "type": "text", "label": "חלון רחב יותר מגדיל את מספר הקודים התקפים בו-זמנית - צמצמו את החלון" }
  ],
  "connections": [
    { "from": "win.2", "to": "st", "label": "מצב אימות" }
  ],
  "animation": {
    "step_seconds": 1.4,
    "steps": [
      { "active": ["verify"] },
      { "active": ["win.0"], "set": { "st": 0 }, "move": { "0": "win.0" } },
      { "active": ["win.1"], "set": { "st": 1 }, "move": { "0": "win.1" } },
      { "active": ["win.2"], "set": { "st": 2 }, "move": { "0": "win.2" } },
      { "active": ["win.3"], "set": { "st": 3 }, "move": { "0": "win.3" } },
      { "active": ["win.4"], "set": { "st": 4 }, "move": { "0": "win.4" } },
      { "active": ["win.1", "win.2", "win.3"], "set": { "st": 5 }, "move": { "0": "win.2" } }
    ]
  }
}
