{
  "title": "לולאת השימוש בכלים: המודל מבקש קריאת tool, אנחנו מריצים את הפונקציה בקוד ומחזירים tool_result, והמודל ממשיך לבקש קריאות עד שהוא מסיים ומחזיר תשובה סופית למשתמש",
  "layout": { "type": "flow" },
  "components": [
    { "id": "msg", "type": "box", "label": "הודעת משתמש + רשימת tools" },
    { "id": "model", "type": "box", "label": "המודל מעבד את השיחה" },
    { "id": "run", "type": "box", "label": "מריצים את הפונקציה בקוד" },
    { "id": "result", "type": "box", "label": "מחזירים tool_result למודל" },
    { "id": "final", "type": "box", "label": "תשובה סופית למשתמש" }
  ],
  "connections": [
    { "from": "msg", "to": "model" },
    { "from": "model", "to": "run", "label": "tool_use" },
    { "from": "run", "to": "result" },
    { "from": "result", "to": "model", "label": "עוד קריאה", "loop": true },
    { "from": "result", "to": "final", "label": "end_turn" }
  ],
  "animation": {
    "step_seconds": 1.6,
    "steps": [
      { "active": ["msg"] },
      { "active": ["model"], "edges": [0] },
      { "active": ["run"], "edges": [1] },
      { "active": ["result"], "edges": [2] },
      { "active": ["model"], "edges": [3] },
      { "active": ["run"], "edges": [1] },
      { "active": ["result"], "edges": [2] },
      { "active": ["final"], "edges": [4] }
    ]
  }
}
