{
  "title": "מצביע בשפת C: המשתנה x שומר ערך, המצביע p שומר את הכתובת של x, ופעולת הכוכבית מחזירה את הערך שבכתובת",
  "layout": { "type": "flow" },
  "components": [
    { "id": "code", "type": "code", "lines": ["int x = 10;", "int* p = &x;", "int y = *p;"] },
    { "id": "xbox", "type": "box", "label": "בכתובת 0x1000 יושב הערך 10, זהו המשתנה x" },
    { "id": "pbox", "type": "box", "label": "המצביע p שומר את הכתובת 0x1000" },
    { "id": "y", "type": "box", "values": ["y = ?", "y = 10"] },
    { "id": "note", "type": "text", "label": "הסימן & נותן את הכתובת של המשתנה, והסימן * נותן את הערך ששמור באותה כתובת" }
  ],
  "connections": [
    { "from": "code", "to": "xbox" },
    { "from": "xbox", "to": "pbox", "label": "&x" },
    { "from": "pbox", "to": "y", "label": "*p" }
  ],
  "animation": {
    "step_seconds": 1.8,
    "steps": [
      { "active": ["code"], "set": { "y": 0 } },
