{
  "title": "ניווט מקלדת עם מקש Tab: הפוקוס עובר בין האלמנטים בדף לפי הסדר",
  "layout": { "type": "stack" },
  "components": [
    { "id": "code", "type": "code", "label": "Tab -> Tab -> Tab" },
    { "id": "lst", "type": "table", "cells": ["קישור", "כפתור", "שדה אימייל", "תיבת סימון"] },
    { "id": "val", "type": "dynamic",
      "values": ["הפוקוס על הקישור", "הפוקוס על הכפתור", "הפוקוס על שדה האימייל", "הפוקוס על תיבת הסימון"] },
    { "id": "note", "type": "text", "label": "כל לחיצה על Tab מעבירה את הפוקוס לאלמנט הבא, ו-Shift+Tab מחזירה אחורה" }
  ],
  "connections": [
    { "from": "lst.0", "to": "val", "label": "הפוקוס" }
  ],
  "animation": {
    "step_seconds": 1.8,
    "steps": [
      { "active": ["lst.0"], "set": { "val": 0 }, "move": { "0": "lst.0" } },
      { "active": ["lst.1"], "set": { "val": 1 }, "move": { "0": "lst.1" } },
      { "active": ["lst.2"], "set": { "val": 2 }, "move": { "0": "lst.2" } },
      { "active": ["lst.3"], "set": { "val": 3 }, "move": { "0": "lst.3" } }
    ]
  }
}
