    "steps": [
      { "active": ["script"], "set": { "addr": 0 }, "move": { "0": "secs.0" } },
      { "active": ["secs.0"], "set": { "addr": 1 }, "move": { "0": "secs.0" } },
      { "active": ["secs.1"], "set": { "addr": 2 }, "move": { "0": "secs.1" } },
      { "active": ["secs.2"], "set": { "addr": 3 }, "move": { "0": "secs.2" } },
      { "active": ["secs.3"], "set": { "addr": 4 }, "move": { "0": "secs.3" } }
    ]
  }
}
