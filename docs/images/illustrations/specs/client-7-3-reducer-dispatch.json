{
  "title": "הפונקציה dispatch שולחת action ל-reducer, ה-reducer בוחר את ה-case המתאים ומחזיר אובייקט state חדש שגורם לרינדור מחדש",
  "layout": { "type": "flow" },
  "components": [
    { "id": "cur", "type": "code", "label": "state = { count: 0 }",
      "values": ["state = { count: 0 }", "state = { count: 1 }"] },
    { "id": "act", "type": "code", "label": "dispatch({ type: \"increment\" })" },
    { "id": "sw", "type": "code",
      "lines": ["case \"increment\":", "  return { count: state.count + 1 }"] },
    { "id": "nxt", "type": "code", "label": "{ count: 1 }" },
    { "id": "rr", "type": "box", "label": "ריאקט מרנדר מחדש את הקומפוננטה" }
  ],
  "connections": [
    { "from": "cur", "to": "act", "label": "לחיצה על הכפתור" },
    { "from": "act", "to": "sw", "label": "ה-action מגיע ל-reducer" },
    { "from": "sw", "to": "nxt", "label": "מחזיר אובייקט חדש" },
    { "from": "nxt", "to": "rr" },
    { "from": "rr", "to": "cur", "label": "הסטייט מתעדכן", "loop": true }
  ],
  "animation": {
    "step_seconds": 1.8,
    "steps": [
      { "active": ["cur"] },
      { "active": ["act"], "edges": [0] },
      { "active": ["sw"], "edges": [1] },
      { "active": ["nxt"], "edges": [2] },
      { "active": ["rr"], "edges": [3] },
      { "active": ["cur"], "edges": [4], "set": { "cur": 1 } }
    ]
  }
}
