    { "id": "ctrl", "type": "box", "label": "ה-Controller מופעל" },
    { "id": "db", "type": "box", "label": "פנייה ל-Database" },
    { "id": "resp", "type": "code", "label": "200 OK + JSON" },
    { "id": "reject", "type": "code", "label": "401 Unauthorized" }
  ],
  "connections": [
    { "from": "req", "to": "json", "label": "הבקשה נכנסת" },
