{
  "title": "מסלול בקשה ב-Express: הבקשה עוברת דרך ה-middleware, נמצא ה-route, נבדק ה-token, ה-controller פונה ל-database ומחזיר JSON",
  "layout": { "type": "flow" },
  "components": [
    { "id": "req", "type": "code", "label": "GET /api/users" },
