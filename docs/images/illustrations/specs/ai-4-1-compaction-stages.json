{
  "title": "כשהcontext מתקרב לגבול Claude Code קודם מנקה פלטים ישנים של tools ורק אם צריך עוד מקום מסכם את השיחה, וכך מתפנה מקום להמשך העבודה",
  "layout": { "type": "flow" },
  "components": [
    { "id": "gauge", "type": "box", "label": "ניצול context", "values": ["195K / 200K", "150K / 200K", "95K / 200K"] },
    { "id": "clear_tools", "type": "box", "label": "ניקוי פלטי tools ישנים" },
    { "id": "check", "type": "diamond", "label": "עדיין צריך מקום?" },
    { "id": "summarize", "type": "box", "label": "סיכום השיחה" },
    { "id": "done", "type": "box", "label": "יש מקום, ממשיכים" }
  ],
  "connections": [
    { "from": "gauge", "to": "clear_tools" },
    { "from": "clear_tools", "to": "check" },
    { "from": "check", "to": "summarize", "label": "כן", "side": "right" },
    { "from": "check", "to": "done", "label": "לא" },
    { "from": "summarize", "to": "done" }
  ],
  "animation": {
    "step_seconds": 1.7,
    "steps": [
      { "active": ["gauge"], "set": { "gauge": 0 } },
      { "active": ["clear_tools"], "edges": [0] },
      { "active": ["check"], "edges": [1], "set": { "gauge": 1 } },
      { "active": ["summarize"], "edges": [2] },
      { "active": ["done"], "edges": [4], "set": { "gauge": 2 } }
    ]
  }
}
