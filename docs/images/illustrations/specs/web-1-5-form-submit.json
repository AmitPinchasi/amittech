{
  "title": "זרימת שליחת טופס: המשתמש ממלא שדה, נשלחת בקשת POST, השרת קורא את הערך דרך _POST ומדפיס תשובה",
  "layout": { "type": "flow" },
  "components": [
    { "id": "form", "type": "box", "label": "המשתמש ממלא את שדה name בטופס" },
    { "id": "submit", "type": "box", "label": "שליחת בקשת POST ל-process.php" },
    { "id": "val", "type": "dynamic",
      "values": ["$_POST['name'] = ?", "$_POST['name'] = \"Dan\""] },
    { "id": "echo", "type": "box", "label": "השרת מדפיס: Hello, Dan" }
  ],
  "connections": [
    { "from": "form", "to": "submit" },
    { "from": "submit", "to": "val", "label": "המידע נשלח לשרת" },
    { "from": "val", "to": "echo" }
  ],
  "animation": {
    "step_seconds": 1.8,
    "steps": [
      { "active": ["form"] },
      { "active": ["submit"], "edges": [0] },
      { "active": ["val"], "edges": [1], "set": { "val": 0 } },
      { "active": ["val"], "set": { "val": 1 } },
      { "active": ["echo"], "edges": [2] }
    ]
  }
}
