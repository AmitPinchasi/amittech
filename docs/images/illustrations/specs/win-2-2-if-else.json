{
  "title": "תרשים זרימה של תנאי if else ב-PowerShell: המשתנה number שווה 10 והתנאי -gt נבדק מול הערך האמיתי כדי לבחור ענף",
  "layout": { "type": "flow" },
  "components": [
    { "id": "input", "type": "code", "label": "$number = 10" },
    { "id": "cond", "type": "diamond", "label": "$number -gt 5",
      "values": ["$number -gt 5", "10 -gt 5"] },
    { "id": "yes", "type": "box", "label": "גדול מ-5" },
    { "id": "no", "type": "box", "label": "5 או פחות" },
    { "id": "end", "type": "box", "label": "המשך הסקריפט" }
  ],
  "connections": [
    { "from": "input", "to": "cond" },
    { "from": "cond", "to": "yes", "label": "אמת", "side": "right" },
    { "from": "cond", "to": "no", "label": "שקר", "side": "left" },
    { "from": "yes", "to": "end" },
    { "from": "no", "to": "end" }
  ],
  "animation": {
    "step_seconds": 1.8,
    "steps": [
      { "active": ["input"] },
      { "active": ["cond"], "set": { "cond": 1 }, "edges": [0] },
      { "active": ["yes"], "edges": [1] },
      { "active": ["end"], "edges": [3] }
    ]
  }
}
