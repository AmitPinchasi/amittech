{
  "title": "תהליך התחברות עם אימייל וסיסמה מבדיקת ה-hash ועד שמירת עוגיית הסשן בדפדפן",
  "layout": { "type": "flow" },
  "components": [
    { "id": "form", "type": "box", "label": "המשתמש שולח אימייל וסיסמה" },
    { "id": "find", "type": "box", "label": "authorize מחפש את המשתמש בבסיס הנתונים" },
    { "id": "cond", "type": "diamond", "label": "bcrypt.compare מאשר?",
      "values": ["bcrypt.compare מאשר?", "לא - הסיסמה שגויה", "כן - הסיסמה נכונה"] },
    { "id": "fail", "type": "box", "label": "מוחזר null וההתחברות נכשלת" },
    { "id": "jwt", "type": "box", "label": "נוצר טוקן סשן עם התפקיד" },
    { "id": "cookie", "type": "box", "label": "עוגיית session נשמרת בדפדפן" }
  ],
  "connections": [
    { "from": "form", "to": "find" },
    { "from": "find", "to": "cond" },
    { "from": "cond", "to": "jwt", "label": "כן" },
    { "from": "jwt", "to": "cookie" },
    { "from": "cond", "to": "fail", "label": "לא", "side": "right" }
  ],
  "animation": {
    "step_seconds": 1.8,
    "steps": [
      { "active": ["form"] },
      { "active": ["find"], "edges": [0] },
      { "active": ["cond"], "set": { "cond": 1 }, "edges": [1] },
      { "active": ["fail"], "edges": [4] },
      { "active": ["cond"], "set": { "cond": 2 } },
      { "active": ["jwt"], "edges": [2] },
      { "active": ["cookie"], "edges": [3] }
    ]
  }
}
