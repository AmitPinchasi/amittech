{
  "title": "זרימת עבודה לכתיבת פיצ'ר עם agent: מטרה, תכנון שחושף שאלות פתוחות לענות עליהן, יישום בצעדים, וסקירת diff שאם מצאה בעיה חוזרת ליישום ורק אחריה מריצים בדיקות",
  "layout": { "type": "flow" },
  "components": [
    { "id": "goal", "type": "box", "label": "מטרה - מה, למה, אילוצים" },
    { "id": "plan", "type": "box", "label": "תכנון לפני קוד" },
    { "id": "q", "type": "diamond", "label": "שאלות פתוחות?" },
    { "id": "answer", "type": "box", "label": "עונים לagent" },
    { "id": "impl", "type": "box", "label": "יישום בצעדים" },
    { "id": "diff", "type": "box", "label": "סקירת diff שורה-שורה" },
    { "id": "review", "type": "diamond", "label": "נמצאה בעיה?" },
    { "id": "tests", "type": "box", "label": "הרצת בדיקות" }
  ],
  "connections": [
    { "from": "goal", "to": "plan" },
    { "from": "plan", "to": "q" },
    { "from": "q", "to": "answer", "label": "כן" },
    { "from": "answer", "to": "impl" },
    { "from": "q", "to": "impl", "label": "לא" },
    { "from": "impl", "to": "diff" },
    { "from": "diff", "to": "review" },
    { "from": "review", "to": "impl", "label": "כן - תיקון", "loop": true },
    { "from": "review", "to": "tests", "label": "לא", "side": "right" }
  ],
  "animation": {
    "step_seconds": 1.6,
    "steps": [
      { "active": ["goal"] },
      { "active": ["plan"], "edges": [0] },
      { "active": ["q"], "edges": [1] },
      { "active": ["answer"], "edges": [2] },
      { "active": ["impl"], "edges": [3] },
      { "active": ["diff"], "edges": [5] },
      { "active": ["review"], "edges": [6] },
      { "active": ["impl"], "edges": [7] },
      { "active": ["diff"], "edges": [5] },
      { "active": ["review"], "edges": [6] },
      { "active": ["tests"], "edges": [8] }
    ]
  }
