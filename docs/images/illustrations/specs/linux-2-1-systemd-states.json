{
  "title": "מכונת המצבים של שירות ב-systemd: הפקודה start מפעילה את השירות והפקודה stop עוצרת אותו",
  "layout": { "type": "flow" },
  "components": [
    { "id": "stopped", "type": "box", "label": "עצור - inactive (dead)" },
    { "id": "running", "type": "box", "label": "פעיל - active (running)" },
    { "id": "cmd", "type": "dynamic", "values": ["systemctl status", "systemctl start", "systemctl stop"] },
    { "id": "note", "type": "text", "label": "הפקודה enable מפעילה את השירות אוטומטית עם ה-boot" }
  ],
  "connections": [
    { "from": "stopped", "to": "running", "label": "systemctl start" },
    { "from": "running", "to": "stopped", "label": "systemctl stop", "loop": true }
  ],
  "animation": {
    "step_seconds": 1.8,
    "steps": [
      { "active": ["stopped"], "set": { "cmd": 0 } },
      { "active": ["running"], "edges": [0], "set": { "cmd": 1 } },
      { "active": ["stopped"], "edges": [1], "set": { "cmd": 2 } }
    ]
  }
}
