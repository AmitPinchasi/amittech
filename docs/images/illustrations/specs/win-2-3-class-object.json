{
  "title": "יצירת אובייקט ממחלקה ב-PowerShell: הקונסטרוקטור ממלא את השדות Name ו-Age, והמתודה Greet קוראת מהם ומרכיבה את הודעת הברכה",
  "layout": { "type": "flow" },
  "components": [
    { "id": "ctor", "type": "code", "label": "$person = [Person]::new(\"John\", 30)" },
    { "id": "obj", "type": "dynamic", "values": [
        "Person { Name = ? , Age = ? }",
        "Person { Name = John , Age = 30 }"
      ] },
    { "id": "greet", "type": "code", "label": "$person.Greet()" },
    { "id": "out", "type": "dynamic", "values": [
        "המתודה עדיין לא רצה",
        "Hello, my name is John and I am 30 years old"
      ] },
    { "id": "note", "type": "text", "label": "האובייקט מחזיק את הנתונים בשדות, והמתודה קוראת אותם בזמן ריצה" }
  ],
  "connections": [
    { "from": "ctor", "to": "obj", "label": "ממלא את השדות" },
    { "from": "obj", "to": "greet", "label": "קוראים למתודה" },
    { "from": "greet", "to": "out", "label": "קוראת מהשדות" }
  ],
  "animation": {
    "step_seconds": 1.8,
    "steps": [
      { "active": ["ctor"], "set": { "obj": 0, "out": 0 } },
      { "active": ["obj"], "edges": [0], "set": { "obj": 1 } },
      { "active": ["greet"], "edges": [1] },
      { "active": ["out"], "edges": [2], "set": { "out": 1 } }
    ]
  }
}
