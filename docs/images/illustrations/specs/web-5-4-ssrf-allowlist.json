{
  "title": "מנגנון SSRF מול הגנת allowlist: כיצד כתובת url שמוזנת על ידי המשתמש גורמת לשרת לפנות לשירות metadata פנימי, וכיצד רשימת hosts מותרים חוסמת את הפנייה",
  "layout": { "type": "flow" },
  "components": [
    { "id": "input", "type": "box", "label": "קלט: url=http://169.254.169.254/meta-data" },
    { "id": "check", "type": "diamond", "label": "הכתובת ב-allowlist?" },
    { "id": "fetch", "type": "box", "label": "file_get_contents שולח בקשה לכתובת שהוזנה" },
    { "id": "leak", "type": "box", "label": "metadata פנימי מחזיר credentials לתוקף" },
    { "id": "deny", "type": "box", "label": "אינה ברשימה / IP פנימי - הבקשה נחסמת" }
  ],
  "connections": [
    { "from": "input", "to": "check" },
    { "from": "check", "to": "fetch", "label": "לא" },
    { "from": "fetch", "to": "leak" },
    { "from": "check", "to": "deny", "label": "כן", "side": "right" }
  ],
  "animation": {
    "step_seconds": 1.7,
    "steps": [
      { "active": ["input"] },
      { "active": ["check"], "edges": [0] },
      { "active": ["deny"], "edges": [3] },
      { "active": ["check"] },
      { "active": ["fetch"], "edges": [1] },
      { "active": ["leak"], "edges": [2] }
    ]
  }
}
