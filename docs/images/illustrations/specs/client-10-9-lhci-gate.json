    "steps": [
      { "active": ["build"] },
      { "active": ["run"], "edges": [0] },
      { "active": ["score"], "set": { "score": 1 }, "edges": [1] },
      { "active": ["cond"], "set": { "cond": 1 }, "edges": [2] },
      { "active": ["fail"], "edges": [4] },
      { "active": ["score"], "set": { "score": 2 } },
      { "active": ["cond"], "set": { "cond": 2 } },
      { "active": ["pass"], "edges": [3] }
    ]
  }
