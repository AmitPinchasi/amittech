{
  "title": "שער איכות עם Lighthouse CI: ציון נמוך מפיל את ה-build",
  "layout": { "type": "flow" },
  "components": [
    { "id": "build", "type": "box", "label": "ה-build נבנה ב-CI" },
    { "id": "run", "type": "box", "label": "הרצת Lighthouse שלוש פעמים" },
    { "id": "score", "type": "code", "label": "performance = ?",
      "values": ["performance = ?", "performance = 0.72", "performance = 0.94"] },
    { "id": "cond", "type": "diamond", "label": "הציון מעל 0.9?",
