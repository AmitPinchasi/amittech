{
  "title": "שלוש השכבות של אתר: הדפדפן פונה לשרת ה-Backend, ה-Backend שולח שאילתת SQL למסד הנתונים, מקבל את המידע ומחזיר אותו כ-JSON לדפדפן, כך שמסד הנתונים לעולם אינו חשוף ישירות ללקוח",
  "layout": { "type": "flow" },
  "components": [
    { "id": "client", "type": "box", "label": "דפדפן - Client" },
    { "id": "backend", "type": "box", "label": "שרת Backend - API ולוגיקה" },
    { "id": "query", "type": "code", "label": "SELECT ... FROM users" },
    { "id": "db", "type": "box", "label": "מסד נתונים - Database" },
    { "id": "data", "type": "box", "label": "המידע חוזר מהמסד" },
    { "id": "back", "type": "box", "label": "ה-Backend מחזיר JSON לדפדפן" }
  ],
  "connections": [
    { "from": "client", "to": "backend", "label": "בקשה" },
    { "from": "backend", "to": "query" },
    { "from": "query", "to": "db" },
    { "from": "db", "to": "data" },
    { "from": "data", "to": "back" }
  ],
  "animation": {
    "step_seconds": 1.7,
    "steps": [
      { "active": ["client"] },
      { "active": ["backend"], "edges": [0] },
      { "active": ["query"], "edges": [1] },
      { "active": ["db"], "edges": [2] },
      { "active": ["data"], "edges": [3] },
      { "active": ["back"], "edges": [4] }
    ]
  }
}
