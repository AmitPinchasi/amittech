{
  "title": "חטיפת WebSocket בין אתרים: הדפדפן מצרף אוטומטית את עוגיית הקורבן ל-handshake, ואם השרת לא בודק Origin החיבור נפתח בזהות הקורבן ומידע נגנב",
  "layout": { "type": "flow" },
  "components": [
    { "id": "login", "type": "box", "label": "הקורבן מחובר - יש עוגיית session" },
    { "id": "visit", "type": "box", "label": "הקורבן גולש לדף התוקף" },
    { "id": "open", "type": "code", "label": "new WebSocket(wss://bank)" },
    { "id": "cookie", "type": "box", "label": "הדפדפן מצרף עוגייה אוטומטית" },
    { "id": "originq", "type": "diamond", "label": "השרת בודק Origin?" },
    { "id": "hijack", "type": "box", "label": "החיבור נפתח בזהות הקורבן" },
    { "id": "steal", "type": "box", "label": "התוקף שולף מידע פרטי" },
    { "id": "blocked", "type": "box", "label": "החיבור נדחה" }
  ],
  "connections": [
    { "from": "login", "to": "visit" },
    { "from": "visit", "to": "open" },
    { "from": "open", "to": "cookie" },
    { "from": "cookie", "to": "originq" },
    { "from": "originq", "to": "hijack", "label": "לא" },
    { "from": "hijack", "to": "steal" },
    { "from": "originq", "to": "blocked", "label": "כן", "side": "right" }
  ],
  "animation": {
    "step_seconds": 1.6,
    "steps": [
      { "active": ["login"] },
      { "active": ["visit"], "edges": [0] },
      { "active": ["open"], "edges": [1] },
      { "active": ["cookie"], "edges": [2] },
      { "active": ["originq"], "edges": [3] },
      { "active": ["blocked"], "edges": [6] },
      { "active": ["originq"] },
      { "active": ["hijack"], "edges": [4] },
      { "active": ["steal"], "edges": [5] }
    ]
  }
}
