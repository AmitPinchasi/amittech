{
  "title": "טסט עם פרמטרים: כל שלשה ברשימה של parametrize מריצה את אותו טסט פעם נוספת עם ערכים אחרים",
  "layout": { "type": "stack" },
  "components": [
    { "id": "code", "type": "code", "label": "@pytest.mark.parametrize" },
    { "id": "lst", "type": "table", "cells": ["(2, 3, 6)", "(-1, 5, -5)", "(0, 100, 0)"] },
    { "id": "val", "type": "dynamic",
      "values": ["assert 2 * 3 == 6", "assert -1 * 5 == -5", "assert 0 * 100 == 0"] },
    { "id": "note", "type": "text", "label": "שלוש שלשות ברשימה - שלושה טסטים נפרדים" }
  ],
  "connections": [
    { "from": "lst.0", "to": "val", "label": "הטסט הנוכחי" }
  ],
  "animation": {
    "step_seconds": 1.8,
    "steps": [
      { "active": ["code"] },
      { "active": ["lst.0"], "set": { "val": 0 }, "move": { "0": "lst.0" } },
      { "active": ["lst.1"], "set": { "val": 1 }, "move": { "0": "lst.1" } },
      { "active": ["lst.2"], "set": { "val": 2 }, "move": { "0": "lst.2" } }
    ]
  }
}
