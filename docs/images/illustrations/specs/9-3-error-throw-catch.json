{
  "title": "פונקציית login זורקת שגיאה ופונקציית safe_login תופסת אותה, כך שהמשתמש לא רואה את השגיאה",
  "layout": { "type": "flow" },
  "components": [
    { "id": "safe", "type": "box", "label": "הפונקציה safe_login קוראת בתוך try",
      "values": ["הפונקציה safe_login קוראת בתוך try", "ה-except של safe_login תופס את השגיאה"] },
    { "id": "login", "type": "code", "label": "login(username, password)",
      "values": ["login(\"dana\", \"1234\")", "login(\"dana\", \"wrong\")"] },
    { "id": "cond", "type": "diamond", "label": "check_password?" },
    { "id": "ok", "type": "box", "label": "session.start()" },
    { "id": "err", "type": "code", "label": "raise AuthenticationException" },
    { "id": "note", "type": "text", "label": "המשתמש אף פעם לא רואה את השגיאה עצמה" }
  ],
  "connections": [
    { "from": "safe", "to": "login", "label": "try" },
    { "from": "login", "to": "cond" },
    { "from": "cond", "to": "ok", "label": "כן", "side": "right" },
    { "from": "cond", "to": "err", "label": "לא" },
    { "from": "err", "to": "safe", "label": "השגיאה עולה", "loop": true }
  ],
  "animation": {
    "step_seconds": 1.6,
    "steps": [
      { "active": ["safe"] },
      { "active": ["login"], "edges": [0] },
      { "active": ["cond"], "edges": [1] },
      { "active": ["ok"], "edges": [2] },
      { "active": ["safe"] },
      { "active": ["login"], "edges": [0], "set": { "login": 1 } },
      { "active": ["cond"], "edges": [1] },
      { "active": ["err"], "edges": [3] },
      { "active": ["safe"], "edges": [4], "set": { "safe": 1 } }
    ]
  }
}
