{
  "title": "ההמתנה האוטומטית של Playwright לפני ביצוע פעולה",
  "layout": { "type": "flow" },
  "components": [
    { "id": "call", "type": "code", "label": "await button.click()" },
    { "id": "cond", "type": "diamond", "label": "האלמנט גלוי ופעיל?",
      "values": ["האלמנט גלוי ופעיל?", "עדיין נטען - לא מוכן", "האלמנט מוכן"] },
    { "id": "wait", "type": "box", "label": "המתנה קצרה" },
    { "id": "act", "type": "box", "label": "הלחיצה מתבצעת" }
  ],
  "connections": [
    { "from": "call", "to": "cond" },
    { "from": "cond", "to": "wait", "label": "לא" },
    { "from": "wait", "to": "cond", "loop": true, "label": "בדיקה חוזרת" },
    { "from": "cond", "to": "act", "label": "כן", "side": "right" }
  ],
  "animation": {
    "step_seconds": 1.8,
    "steps": [
      { "active": ["call"] },
      { "active": ["cond"], "set": { "cond": 1 } },
      { "active": ["wait"], "edges": [1] },
      { "edges": [2] },
      { "active": ["cond"] },
      { "active": ["wait"], "edges": [1] },
      { "edges": [2] },
      { "active": ["cond"], "set": { "cond": 2 } },
      { "active": ["act"], "edges": [3] }
    ]
  }
}
