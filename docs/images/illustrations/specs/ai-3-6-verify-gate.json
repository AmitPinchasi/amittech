{
  "title": "שער אימות לעבודת agent: המשפט סיימתי הוא טענה ולא עובדה, לכן דורשים ראיה של הרצה בפועל וdiff ובדיקות, ואם הראיה לא מוכיחה חוזרים לתיקון, ורק ראיה שמוכיחה מובילה לאישור",
  "layout": { "type": "flow" },
  "components": [
    { "id": "claim", "type": "box", "label": "טענה - המשימה הושלמה" },
    { "id": "evidence", "type": "box", "label": "דורשים ראיה - הרצה, diff, בדיקות" },
    { "id": "gate", "type": "diamond", "label": "הראיה מוכיחה?" },
    { "id": "fix", "type": "box", "label": "חזרה לagent לתיקון" },
    { "id": "accept", "type": "box", "label": "מאשרים בביטחון" }
  ],
  "connections": [
    { "from": "claim", "to": "evidence" },
    { "from": "evidence", "to": "gate" },
    { "from": "gate", "to": "fix", "label": "לא" },
    { "from": "fix", "to": "evidence", "label": "בודקים שוב", "loop": true },
    { "from": "gate", "to": "accept", "label": "כן", "side": "right" }
  ],
  "animation": {
    "step_seconds": 1.6,
    "steps": [
      { "active": ["claim"] },
      { "active": ["evidence"], "edges": [0] },
      { "active": ["gate"], "edges": [1] },
      { "active": ["fix"], "edges": [2] },
      { "active": ["evidence"], "edges": [3] },
      { "active": ["gate"], "edges": [1] },
      { "active": ["accept"], "edges": [4] }
    ]
  }
}
