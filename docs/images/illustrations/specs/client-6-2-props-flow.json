{
  "title": "הנתונים זורמים בכיוון אחד מקומפוננטת האב לקומפוננטת הבן דרך פרופס, וכשהאב משנה ערך הבן מרנדר מחדש",
  "layout": { "type": "flow" },
  "components": [
    { "id": "app", "type": "box", "label": "App - קומפוננטת אב" },
    { "id": "props", "type": "code",
      "label": "<Greeting name=\"Alice\" />",
      "values": ["<Greeting name=\"Alice\" />", "<Greeting name=\"Bob\" />"] },
    { "id": "child", "type": "box", "label": "Greeting - קומפוננטת בן" },
    { "id": "out", "type": "code",
      "label": "Hello, Alice!",
      "values": ["Hello, Alice!", "Hello, Bob!"] }
  ],
  "connections": [
    { "from": "app", "to": "props", "label": "האב קובע את הפרופס" },
    { "from": "props", "to": "child", "label": "הפרופס עוברים לבן" },
    { "from": "child", "to": "out", "label": "הבן מרנדר את הפרופס" }
  ],
  "animation": {
    "step_seconds": 1.8,
    "steps": [
      { "active": ["app"] },
      { "active": ["props"], "edges": [0], "set": { "props": 0 } },
      { "active": ["child"], "edges": [1] },
      { "active": ["out"], "edges": [2], "set": { "out": 0 } },
      { "active": ["app", "props"], "set": { "props": 1 } },
      { "active": ["out"], "edges": [1, 2], "set": { "out": 1 } }
    ]
  }
}
