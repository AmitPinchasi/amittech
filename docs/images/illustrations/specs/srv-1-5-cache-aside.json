{
  "title": "דפוס Cache-Aside עם Redis: בקשה ראשונה לא נמצאת במטמון ולכן נשלפת מה-DB ונשמרת ב-Redis, ובקשה חוזרת מוחזרת ישירות מהזיכרון",
  "layout": { "type": "flow" },
  "components": [
    { "id": "req", "type": "code", "label": "GET /trips/123" },
    { "id": "cache", "type": "diamond", "label": "קיים ב-Redis?" },
    { "id": "db", "type": "box", "label": "שליפה ממסד הנתונים" },
    { "id": "store", "type": "box", "label": "שמירה ב-Redis עם TTL" },
    { "id": "resp", "type": "box", "label": "מחזירים למשתמש" },
    { "id": "hit", "type": "box", "label": "מוחזר מהזיכרון" }
  ],
  "connections": [
    { "from": "req", "to": "cache" },
    { "from": "cache", "to": "db", "label": "לא - miss" },
    { "from": "db", "to": "store" },
    { "from": "store", "to": "resp" },
    { "from": "cache", "to": "hit", "label": "כן - hit", "side": "right" },
    { "from": "hit", "to": "resp" }
  ],
  "animation": {
    "step_seconds": 1.7,
    "steps": [
      { "active": ["req"] },
      { "active": ["cache"], "edges": [0] },
      { "active": ["db"], "edges": [1] },
      { "active": ["store"], "edges": [2] },
      { "active": ["resp"], "edges": [3] },
      { "active": ["req"] },
      { "active": ["cache"], "edges": [0] },
      { "active": ["hit"], "edges": [4] },
      { "active": ["resp"], "edges": [5] }
    ]
  }
}
