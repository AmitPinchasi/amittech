{
  "title": "מלכודת פוקוס במודל: המקש Tab מעביר את הפוקוס בין האלמנטים, ומהאלמנט האחרון הפוקוס חוזר לראשון במקום לברוח לרקע",
  "layout": { "type": "stack" },
  "components": [
    { "id": "lst", "type": "table", "cells": ["שם", "אימייל", "שלח", "ביטול"] },
    { "id": "focus", "type": "dynamic",
      "values": ["הפוקוס על האלמנט הראשון", "לחיצה על Tab - הפוקוס מתקדם", "המקש Tab באלמנט האחרון מחזיר לראשון"] },
    { "id": "note", "type": "text", "label": "כל עוד המודל פתוח, הפוקוס נע במעגל סגור ולא בורח לדף שמאחור" }
  ],
  "connections": [
    { "from": "lst.0", "to": "focus", "label": "הפוקוס" }
  ],
  "animation": {
    "step_seconds": 1.5,
    "steps": [
      { "active": ["lst.0"], "set": { "focus": 0 } },
      { "active": ["lst.1"], "set": { "focus": 1 }, "move": { "0": "lst.1" } },
      { "active": ["lst.2"], "set": { "focus": 1 }, "move": { "0": "lst.2" } },
      { "active": ["lst.3"], "set": { "focus": 1 }, "move": { "0": "lst.3" } },
      { "active": ["lst.0"], "set": { "focus": 2 }, "move": { "0": "lst.0" } }
    ]
  }
}
