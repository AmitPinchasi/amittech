{
  "title": "שרת שמפצל process לכל חיבור: הילד מקבל עותק של מתאר הלקוח והאב חוזר להאזין",
  "layout": { "type": "stack" },
  "components": [
    { "id": "code", "type": "code", "values": [
      "client_fd = accept(server_fd, ...);",
      "pid = fork();",
      "parent: close(client_fd);",
      "child: handle_client(); exit(0);"
    ] },
    { "id": "par", "type": "dynamic", "values": [
      "parent: fd 3 = listen, fd 4 = client",
      "parent: fd 3 = listen"
    ] },
    { "id": "chi", "type": "dynamic", "values": [
      "child: none",
      "child: fd 3 = listen, fd 4 = client",
      "child: fd 4 = client",
      "child: exit(0)"
    ] },
    { "id": "note", "type": "box", "values": [
