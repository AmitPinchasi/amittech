{
  "title": "גישת mobile-first: שאילתות מדיה עם min-width נכנסות לתוקף כשהמסך מתרחב",
  "layout": { "type": "stack" },
  "components": [
    { "id": "vw", "type": "dynamic",
      "values": ["viewport = 400px", "viewport = 800px", "viewport = 1200px"] },
    { "id": "base", "type": "code", "label": "grid-template-columns: 1fr" },
    { "id": "mq1", "type": "code",
      "lines": ["@media (min-width: 768px)", "grid-template-columns: repeat(2, 1fr)"] },
    { "id": "mq2", "type": "code",
      "lines": ["@media (min-width: 1024px)", "grid-template-columns: repeat(3, 1fr)"] },
    { "id": "result", "type": "dynamic",
      "values": ["עמודה אחת", "שתי עמודות", "שלוש עמודות"] },
    { "id": "note", "type": "text",
      "label": "הבסיס מיועד למובייל, וכל שאילתה שהתנאי שלה מתקיים דורסת את הכללים שלפניה" }
  ],
  "connections": [],
  "animation": {
    "step_seconds": 2.4,
    "steps": [
      { "active": ["vw", "base", "result"] },
      { "active": ["vw", "mq1", "result"], "set": { "vw": 1, "result": 1 } },
      { "active": ["vw", "mq2", "result"], "set": { "vw": 2, "result": 2 } }
    ]
  }
}
