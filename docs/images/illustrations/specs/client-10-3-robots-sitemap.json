{
  "title": "תהליך הסריקה: הבוט קורא robots.txt, מוצא את ה-sitemap ומחליט אילו דפים לסרוק",
  "layout": { "type": "flow" },
  "components": [
    { "id": "bot", "type": "box", "label": "הבוט מגיע לאתר" },
    { "id": "robots", "type": "code", "lines": [
      "User-agent: *",
      "Disallow: /admin/",
      "Sitemap: /sitemap.xml"
    ] },
    { "id": "list", "type": "box", "label": "רשימת הדפים מה-sitemap" },
    { "id": "cond", "type": "diamond", "label": "מותר לסרוק?",
      "values": ["מותר לסרוק?", "חסום: /admin/", "מותר: /products"] },
    { "id": "crawl", "type": "box", "label": "הדף נסרק ונשלח לאינדוקס" },
    { "id": "skip", "type": "box", "label": "הדף מדולג" }
  ],
  "connections": [
    { "from": "bot", "to": "robots", "label": "קורא robots.txt" },
    { "from": "robots", "to": "list" },
    { "from": "list", "to": "cond" },
    { "from": "cond", "to": "crawl", "label": "כן" },
    { "from": "cond", "to": "skip", "label": "לא", "side": "right" }
  ],
  "animation": {
    "step_seconds": 1.8,
    "steps": [
      { "active": ["bot"] },
      { "active": ["robots"], "edges": [0] },
      { "active": ["list"], "edges": [1] },
      { "active": ["cond"], "set": { "cond": 1 }, "edges": [2] },
      { "active": ["skip"], "edges": [4] },
      { "active": ["cond"], "set": { "cond": 2 } },
      { "active": ["crawl"], "edges": [3] }
    ]
  }
}
