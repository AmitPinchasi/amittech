    "steps": [
      { "active": ["init"], "set": { "state": 0 } },
      { "active": ["dev"], "edges": [0], "set": { "state": 1 } },
      { "active": ["ctx"], "edges": [1], "set": { "state": 2 } },
      { "active": ["mod"], "edges": [2], "set": { "state": 3 } },
