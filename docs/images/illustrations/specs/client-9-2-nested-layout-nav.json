{
  "title": "ניווט בין דפים בתוך הדשבורד שבו הלייאאוטים נשארים ורק תוכן הדף מתחלף",
  "layout": { "type": "flow" },
  "components": [
    { "id": "nav", "type": "box", "label": "המשתמש נמצא ב-dashboard/settings",
      "values": ["המשתמש נמצא ב-dashboard/settings", "לחיצה על הקישור ל-dashboard/analytics"] },
    { "id": "root", "type": "box", "label": "layout ראשי - לא מתרנדר מחדש" },
    { "id": "dash", "type": "box", "label": "layout של הדשבורד - שומר את ה-state" },
    { "id": "page", "type": "dynamic",
      "values": ["page.tsx של ההגדרות", "page.tsx של האנליטיקס"] }
  ],
  "connections": [
    { "from": "nav", "to": "root" },
    { "from": "root", "to": "dash" },
    { "from": "dash", "to": "page" }
  ],
  "animation": {
    "step_seconds": 1.8,
    "steps": [
      { "active": ["page"], "set": { "nav": 0, "page": 0 } },
      { "active": ["nav"], "set": { "nav": 1 } },
      { "active": ["root"], "edges": [0] },
      { "active": ["dash"], "edges": [1] },
      { "active": ["page"], "set": { "page": 1 }, "edges": [2] }
    ]
  }
}
