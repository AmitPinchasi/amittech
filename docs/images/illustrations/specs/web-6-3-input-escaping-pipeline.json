  "animation": {
    "step_seconds": 1.6,
    "steps": [
      { "active": ["input"] },
      { "active": ["raw"], "edges": [0] },
      { "active": ["escape"], "edges": [1] },
      { "active": ["safe"], "edges": [2] },
      { "active": ["render"], "edges": [3] }
