{
  "title": "מסלול בקשה במודל MVC: ה-Controller מקבל את הבקשה, יוצר Model עם הנתונים ומעביר אותו ל-View שמרנדר HTML, וההודעה חוזרת למשתמש",
  "layout": { "type": "flow" },
  "components": [
    { "id": "req", "type": "box", "label": "בקשה מהמשתמש" },
    { "id": "ctrl", "type": "box", "label": "Controller - שולט בתהליך" },
    { "id": "model", "type": "code", "label": "new User('Alice')" },
    { "id": "view", "type": "box", "label": "View מציג את ה-Model" },
    { "id": "html", "type": "code", "label": "<h1>Welcome, Alice</h1>" },
    { "id": "resp", "type": "box", "label": "התוצאה חוזרת למשתמש" }
  ],
  "connections": [
    { "from": "req", "to": "ctrl" },
    { "from": "ctrl", "to": "model", "label": "יוצר Model" },
    { "from": "model", "to": "view", "label": "מעביר ל-View" },
    { "from": "view", "to": "html", "label": "מרנדר" },
    { "from": "html", "to": "resp" }
  ],
  "animation": {
    "step_seconds": 1.8,
    "steps": [
      { "active": ["req"] },
      { "active": ["ctrl"], "edges": [0] },
      { "active": ["model"], "edges": [1] },
      { "active": ["view"], "edges": [2] },
      { "active": ["html"], "edges": [3] },
      { "active": ["resp"], "edges": [4] }
    ]
  }
}
