{
  "title": "איור הקשר בין סקשנים לסגמנטים בקובץ ELF: כל סקשן נכנס לסגמנט טעינה עם ההרשאות שלו, וסקשני הsymbols כלל לא נטענים לזכרון",
  "layout": { "type": "stack" },
  "components": [
    { "id": "cmd", "type": "code", "label": "readelf -l ./my_program" },
    { "id": "sec", "type": "table", "cells": [".text", ".rodata", ".data", ".bss", ".symtab"] },
    { "id": "seg", "type": "dynamic", "values": [
      "סגמנט PT_LOAD עם R-X",
      "סגמנט PT_LOAD עם R--",
      "סגמנט PT_LOAD עם RW-",
      "אותו סגמנט RW-, בלי מקום בקובץ",
      "לא נטען לזכרון כלל"
    ] },
    { "id": "note", "type": "text", "label": "הלינקר עובד עם סקשנים, והקרנל טוען סגמנטים, ולכן מספר סקשנים יכולים לשבת בתוך סגמנט אחד" }
  ],
  "connections": [
    { "from": "sec.0", "to": "seg", "label": "הסקשן הנבדק" }
  ],
  "animation": {
    "step_seconds": 1.8,
    "steps": [
      { "active": ["cmd"], "set": { "seg": 0 }, "move": { "0": "sec.0" } },
      { "active": ["sec.0"], "set": { "seg": 0 }, "move": { "0": "sec.0" } },
      { "active": ["sec.1"], "set": { "seg": 1 }, "move": { "0": "sec.1" } },
      { "active": ["sec.2"], "set": { "seg": 2 }, "move": { "0": "sec.2" } },
      { "active": ["sec.3"], "set": { "seg": 3 }, "move": { "0": "sec.3" } },
      { "active": ["sec.4"], "set": { "seg": 4 }, "move": { "0": "sec.4" } }
    ]
  }
}
