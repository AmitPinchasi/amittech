{
  "title": "צינור PowerShell מעביר אובייקטים שלמים בין הפקודות: Get-Process מייצר אובייקטי process, Where-Object מסנן לפי השדה Name, ורק מה שנשאר עובר ל-Stop-Process",
  "layout": { "type": "flow" },
  "components": [
    { "id": "gp", "type": "code", "label": "Get-Process" },
    { "id": "obj1", "type": "dynamic", "values": [
        "אובייקטי process עם שדות Name, Id, CPU",
        "notepad   chrome   explorer"
      ] },
    { "id": "wo", "type": "code", "label": "Where-Object { $_.Name -like \"notepad\" }" },
    { "id": "obj2", "type": "dynamic", "values": [
        "בודקת את השדה Name של כל אובייקט",
        "נשאר רק האובייקט notepad"
      ] },
    { "id": "sp", "type": "code", "label": "Stop-Process" },
    { "id": "note", "type": "text", "label": "ב-| עוברים אובייקטים שלמים עם שדות, לא טקסט כמו ב-Batch" }
  ],
  "connections": [
    { "from": "gp", "to": "obj1", "label": "מייצר אובייקטים" },
    { "from": "obj1", "to": "wo", "label": "הזרם עובר ב-|" },
    { "from": "wo", "to": "obj2", "label": "מסנן את הזרם" },
    { "from": "obj2", "to": "sp", "label": "מעביר את מה שנשאר" }
  ],
  "animation": {
    "step_seconds": 1.7,
    "steps": [
      { "active": ["gp"], "set": { "obj1": 0, "obj2": 0 } },
      { "active": ["obj1"], "edges": [0], "set": { "obj1": 1 } },
      { "active": ["wo"], "edges": [1] },
      { "active": ["obj2"], "edges": [2], "set": { "obj2": 0 } },
      { "active": ["obj2"], "set": { "obj2": 1 } },
      { "active": ["sp"], "edges": [3] }
    ]
  }
}
