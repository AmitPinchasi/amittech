{
  "title": "מחזור החיים של סוקט TCP: השרת מאזין, הלקוח מתחבר, והם מחליפים ping request ו-ping reply",
  "layout": { "type": "flow" },
  "components": [
    { "id": "srv", "type": "box", "label": "השרת: socket, bind, listen" },
    { "id": "accept", "type": "box", "label": "השרת: accept - ממתין לחיבור" },
    { "id": "client", "type": "box", "label": "הלקוח: socket, connect" },
    { "id": "conn", "type": "box", "label": "החיבור נוצר (TCP)" },
    { "id": "req", "type": "code", "label": "sendall(b'ping request')" },
    { "id": "rep", "type": "code", "label": "conn.sendall(b'ping reply')" },
    { "id": "out", "type": "dynamic", "values": ["recv(1024) ממתין", "Received: ping reply"] }
  ],
  "connections": [
    { "from": "srv", "to": "accept" },
    { "from": "accept", "to": "client" },
    { "from": "client", "to": "conn", "label": "connect" },
    { "from": "conn", "to": "req" },
    { "from": "req", "to": "rep", "label": "השרת מקבל ומשיב" },
    { "from": "rep", "to": "out" }
  ],
  "animation": {
    "step_seconds": 1.6,
    "steps": [
      { "active": ["srv"] },
      { "active": ["accept"], "edges": [0] },
      { "active": ["client"], "edges": [1] },
      { "active": ["conn"], "edges": [2] },
      { "active": ["req"], "edges": [3] },
      { "active": ["rep"], "edges": [4] },
      { "active": ["out"], "edges": [5], "set": { "out": 1 } }
    ]
  }
}
