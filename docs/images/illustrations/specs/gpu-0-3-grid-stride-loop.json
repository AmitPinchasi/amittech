{
  "title": "לולאת grid-stride: thread בודד מדלג על המערך בצעדים בגודל stride ומטפל באיברים 0, 2, 4, 6",
  "layout": { "type": "stack" },
  "components": [
    { "id": "code", "type": "code", "label": "for (i = idx; i < n; i += stride)" },
    { "id": "arr", "type": "table", "cells": ["0", "1", "2", "3", "4", "5", "6", "7"] },
    { "id": "cur", "type": "dynamic", "values": ["i = 0", "i = 2", "i = 4", "i = 6", "i = 8"] },
    { "id": "note", "type": "text", "label": "עם stride = 2, thread 0 מטפל באיברים 0, 2, 4, 6 ונעצר כאשר i מגיע ל-8" }
  ],
  "connections": [
    { "from": "arr.0", "to": "cur", "label": "thread 0" }
  ],
  "animation": {
    "step_seconds": 1.8,
    "steps": [
      { "active": ["code"] },
      { "active": ["arr.0"], "set": { "cur": 0 }, "move": { "0": "arr.0" } },
      { "active": ["arr.2"], "set": { "cur": 1 }, "move": { "0": "arr.2" } },
      { "active": ["arr.4"], "set": { "cur": 2 }, "move": { "0": "arr.4" } },
      { "active": ["arr.6"], "set": { "cur": 3 }, "move": { "0": "arr.6" } },
      { "set": { "cur": 4 }, "move": { "0": "arr.6" } }
    ]
  }
}
