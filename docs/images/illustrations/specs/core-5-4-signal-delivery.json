{
  "title": "איור מסירת סיגנל לתהליך: הקרנל עוצר את הלולאה הראשית, מריץ את הhandler שמשנה את הדגל running מ-1 ל-0, ומחזיר את השליטה לקוד שהופסק",
  "layout": { "type": "flow" },
  "components": [
    { "id": "loop", "type": "code", "label": "while (running)",
      "values": ["running = 1", "running = 0"] },
    { "id": "sig", "type": "box", "label": "המשתמש לוחץ Ctrl+C והקרנל שולח SIGINT לתהליך" },
    { "id": "save", "type": "box", "label": "הקרנל עוצר את התהליך ושומר את הקונטקסט שלו" },
    { "id": "hand", "type": "box", "label": "הפונקציה handler רצה",
      "values": ["הפונקציה handler רצה", "הפונקציה handler מציבה running = 0"] },
    { "id": "back", "type": "box", "label": "הקרנל מחזיר את השליטה לקוד בדיוק מהמקום שנעצר" },
    { "id": "cond", "type": "diamond", "label": "running",
      "values": ["running", "running = 1", "running = 0"] },
    { "id": "exit", "type": "box", "label": "יציאה נקייה" }
  ],
  "connections": [
    { "from": "loop", "to": "sig" },
    { "from": "sig", "to": "save" },
    { "from": "save", "to": "hand" },
    { "from": "hand", "to": "back" },
    { "from": "back", "to": "cond" },
    { "from": "cond", "to": "exit", "label": "לא", "side": "right" },
    { "from": "cond", "to": "loop", "label": "כן", "loop": true }
  ],
  "animation": {
    "step_seconds": 1.8,
    "steps": [
      { "active": ["loop"], "set": { "loop": 0, "hand": 0, "cond": 0 } },
      { "active": ["sig"], "edges": [0] },
      { "active": ["save"], "edges": [1] },
      { "active": ["hand"], "edges": [2], "set": { "hand": 1, "loop": 1 } },
      { "active": ["back"], "edges": [3] },
      { "active": ["cond"], "edges": [4], "set": { "cond": 2 } },
      { "active": ["exit"], "edges": [5] }
    ]
  }
}
