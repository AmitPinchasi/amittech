{
  "title": "איור פתרון symbols: הלינקר עובר על כל symbol ומחפש את הקובץ שמגדיר אותו",
  "layout": { "type": "stack" },
  "components": [
    { "id": "cmd", "type": "code", "label": "gcc main.o math_utils.o -o program" },
    { "id": "syms", "type": "table", "cells": ["main", "add", "multiply", "printf"] },
    { "id": "res", "type": "dynamic", "values": [
      "מוגדר בתוך main.o, בסקשן text",
      "חסר ב-main.o, ההגדרה נמצאת ב-math_utils.o",
      "חסר ב-main.o, ההגדרה נמצאת ב-math_utils.o",
      "חסר בכל קבצי האובייקט, ההגדרה מגיעה מ-libc"
    ] },
    { "id": "note", "type": "text", "label": "כל symbol שנשאר בלי הגדרה מסיים בשגיאת undefined reference" }
  ],
  "connections": [
    { "from": "syms.0", "to": "res", "label": "הsymbol הנבדק" }
  ],
  "animation": {
    "step_seconds": 1.8,
    "steps": [
      { "active": ["cmd"], "set": { "res": 0 }, "move": { "0": "syms.0" } },
      { "active": ["syms.0"], "set": { "res": 0 }, "move": { "0": "syms.0" } },
      { "active": ["syms.1"], "set": { "res": 1 }, "move": { "0": "syms.1" } },
      { "active": ["syms.2"], "set": { "res": 2 }, "move": { "0": "syms.2" } },
      { "active": ["syms.3"], "set": { "res": 3 }, "move": { "0": "syms.3" } }
    ]
  }
}
