    { "id": "prevsize", "type": "box", "label": "prev_size (8 בתים)" },
    { "id": "sizef", "type": "box", "label": "size + דגלים (8 בתים)" },
    { "id": "memmark", "type": "text", "label": "mem - הכתובת שmalloc מחזיר" },
    { "id": "field1", "type": "box", "values": ["נתוני משתמש - 8 בתים ראשונים", "fd - מצביע ל-chunk הבא בפח"] },
    { "id": "field2", "type": "box", "values": ["נתוני משתמש - 8 בתים הבאים", "bk - מצביע ל-chunk הקודם בפח"] },
    { "id": "rest", "type": "box", "values": ["...נתוני משתמש נוספים...", "...זבל ישן..."] },
