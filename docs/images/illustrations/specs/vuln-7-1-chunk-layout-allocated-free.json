  ],
  "animation": {
    "step_seconds": 2.0,
    "steps": [
      { "active": ["state", "field1", "field2", "rest"], "set": { "state": 0, "field1": 0, "field2": 0, "rest": 0 } },
      { "active": ["state", "field1", "field2", "rest"], "set": { "state": 1, "field1": 1, "field2": 1, "rest": 1 } }
    ]
  }
}
