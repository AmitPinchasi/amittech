{
  "title": "ההבדל בין em ל-rem: חישוב גודל פונט יחסי להורה מול יחסי לשורש",
  "layout": { "type": "stack" },
  "components": [
    { "id": "root", "type": "code", "label": "html { font-size: 16px }" },
    { "id": "parent", "type": "code", "label": ".parent { font-size: 1.5em }" },
    { "id": "child", "type": "code", "label": ".child { font-size: 1.5em }",
      "values": [".child { font-size: 1.5em }", ".child { font-size: 1.5rem }"] },
    { "id": "size", "type": "dynamic",
      "values": ["parent: 16 * 1.5 = 24px", "em: 24 * 1.5 = 36px", "rem: 16 * 1.5 = 24px"] },
    { "id": "note", "type": "text",
      "label": "היחידה em מוכפלת בגודל ההורה ומצטברת בקינון, בעוד rem מחושבת תמיד מגודל השורש" }
  ],
  "connections": [],
  "animation": {
    "step_seconds": 2.0,
    "steps": [
      { "active": ["root"] },
      { "active": ["parent", "size"] },
      { "active": ["child", "size"], "set": { "size": 1 } },
      { "active": ["child"], "set": { "child": 1 } },
      { "active": ["child", "size"], "set": { "size": 2 } }
    ]
  }
