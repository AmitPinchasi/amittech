{
  "title": "אנימציה של חטיפת זרימה על ידי דריסת GOT - הקריאה עוברת דרך PLT אל תא ה-GOT בעקיפין, כתיבה שרירותית דורסת את הכתובת שבתא, והקריאה הבאה לאותה פונקציה קופצת לקוד הניצחון במקום ל-libc",
  "layout": { "type": "flow" },
  "components": [
    { "id": "call", "type": "box", "label": "הקוד קורא ל-printf@plt" },
    { "id": "plt", "type": "box", "label": "PLT stub - jmp *[GOT entry]" },
    { "id": "got", "type": "dynamic", "values": ["תא ה-GOT מצביע על printf האמיתי ב-libc", "תא ה-GOT נדרס עם %n - מצביע כעת על win"] },
    { "id": "target", "type": "dynamic", "values": ["הזרימה הרגילה - printf רץ", "הקוד שדרסנו רץ - win() קורא ל-system(\"/bin/sh\")"] }
  ],
  "connections": [
    { "from": "call", "to": "plt" },
    { "from": "plt", "to": "got" },
    { "from": "got", "to": "target" }
  ],
  "animation": {
    "step_seconds": 1.8,
    "steps": [
      { "active": ["call", "plt", "got", "target"], "set": { "got": 0, "target": 0 } },
      { "active": ["got"], "set": { "got": 1 } },
      { "active": ["call", "plt", "got", "target"], "set": { "got": 1, "target": 1 } }
    ]
  }
}
