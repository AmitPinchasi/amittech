{
  "title": "הרצת סקריפט Batch שורה אחר שורה: set שומר ערך במשתנה, ו-echo מרחיבה את %message% לערך ומדפיסה אותו",
  "layout": { "type": "flow" },
  "components": [
    { "id": "l1", "type": "code", "label": "set message=Hello World" },
    { "id": "var", "type": "dynamic", "values": ["message = ?", "message = Hello World"] },
    { "id": "l2", "type": "code", "label": "echo %message%" },
    { "id": "out", "type": "dynamic", "values": ["(אין פלט עדיין)", "Hello World"] },
    { "id": "note", "type": "text", "label": "ה-Shell מריץ שורה אחר שורה, ומחליף את %message% בערך שנשמר במשתנה" }
  ],
  "connections": [
    { "from": "l1", "to": "var", "label": "שומר את הערך" },
    { "from": "var", "to": "l2", "label": "%message% מוחלף בערך" },
    { "from": "l2", "to": "out", "label": "מדפיס למסך" }
  ],
  "animation": {
    "step_seconds": 1.7,
    "steps": [
      { "active": ["l1"], "set": { "var": 0, "out": 0 } },
      { "active": ["var"], "edges": [0], "set": { "var": 1 } },
      { "active": ["l2"], "edges": [1] },
      { "active": ["out"], "edges": [2], "set": { "out": 1 } }
    ]
  }
}
