{
  "title": "אקספילטרציה סדרתית ב-CSS: בכל סבב סלקטור תואם קידומת ארוכה יותר של הטוקן, הדפדפן טוען URL לשרת התוקף, והמחרוזת שנחשפה גדלה תו אחר תו",
  "layout": { "type": "stack" },
  "components": [
    { "id": "target", "type": "code", "label": "hidden csrf value = a7f3" },
    { "id": "sel", "type": "dynamic", "values": ["input[value^=a]", "input[value^=a7]", "input[value^=a7f]", "input[value^=a7f3]"] },
    { "id": "req", "type": "dynamic", "values": ["url(/leak?p=a)", "url(/leak?p=a7)", "url(/leak?p=a7f)", "url(/leak?p=a7f3)"] },
    { "id": "server", "type": "box", "label": "שרת התוקף מחזיר import לתו הבא" },
    { "id": "note", "type": "text", "label": "כל סבב חושף תו נוסף, והשרת מחזיר חוקים לתו הבא עד שהטוקן כולו דולף" }
  ],
  "connections": [
    { "from": "sel", "to": "req", "label": "הקידומת תואמת - הדפדפן טוען URL" },
    { "from": "req", "to": "server" }
  ],
  "animation": {
    "step_seconds": 1.8,
    "steps": [
      { "active": ["target"] },
      { "active": ["sel", "req"], "set": { "sel": 0, "req": 0 } },
      { "active": ["sel", "req"], "set": { "sel": 1, "req": 1 } },
      { "active": ["sel", "req"], "set": { "sel": 2, "req": 2 } },
      { "active": ["sel", "req"], "set": { "sel": 3, "req": 3 } }
    ]
  }
}
