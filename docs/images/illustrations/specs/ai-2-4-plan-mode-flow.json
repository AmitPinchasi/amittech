{
  "title": "זרימת מצב תכנון: חקירה בקריאה בלבד, הצגת תוכנית, סבב משוב שמעדכן אותה, ואז אישור וביצוע",
  "layout": { "type": "flow" },
  "components": [
    { "id": "enter", "type": "box", "label": "כניסה למצב plan" },
    { "id": "describe", "type": "box", "label": "מתארים את המשימה" },
    { "id": "investigate", "type": "box", "label": "חקירה - קריאה בלבד" },
    { "id": "plan", "type": "box", "label": "תוכנית ראשונה", "values": ["תוכנית ראשונה", "תוכנית מעודכנת"] },
    { "id": "approve", "type": "diamond", "label": "מאשרים?" },
    { "id": "feedback", "type": "box", "label": "משוב - המשך לתכנן" },
    { "id": "execute", "type": "box", "label": "ביצוע - עריכת קוד" },
    { "id": "review", "type": "box", "label": "סקירה ואימות" }
  ],
  "connections": [
    { "from": "enter", "to": "describe" },
    { "from": "describe", "to": "investigate" },
    { "from": "investigate", "to": "plan" },
    { "from": "plan", "to": "approve" },
    { "from": "approve", "to": "feedback", "label": "לא", "side": "right" },
    { "from": "feedback", "to": "plan", "loop": true },
    { "from": "approve", "to": "execute", "label": "כן" },
    { "from": "execute", "to": "review" }
  ],
  "animation": {
    "step_seconds": 1.5,
    "steps": [
      { "active": ["enter"] },
      { "active": ["describe"], "edges": [0] },
      { "active": ["investigate"], "edges": [1] },
      { "active": ["plan"], "edges": [2], "set": { "plan": 0 } },
      { "active": ["approve"], "edges": [3] },
      { "active": ["feedback"], "edges": [4] },
      { "active": ["plan"], "edges": [5], "set": { "plan": 1 } },
      { "active": ["approve"], "edges": [3] },
      { "active": ["execute"], "edges": [6] },
      { "active": ["review"], "edges": [7] }
    ]
  }
}
