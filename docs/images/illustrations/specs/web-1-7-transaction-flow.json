    { "id": "cond", "type": "diamond", "label": "stock >= quantity" },
    { "id": "apply", "type": "box", "label": "יצירת ההזמנה ועדכון המלאי" },
    { "id": "commit", "type": "box", "label": "commit - שמירת השינויים" },
    { "id": "rollback", "type": "box", "label": "rollback - ביטול כל השינויים" }
  ],
  "connections": [
    { "from": "begin", "to": "check" },
    { "from": "check", "to": "cond" },
    { "from": "cond", "to": "apply", "label": "מלאי מספיק" },
    { "from": "apply", "to": "commit" },
    { "from": "cond", "to": "rollback", "side": "right", "label": "אין מלאי" }
  ],
  "animation": {
    "step_seconds": 1.8,
    "steps": [
      { "active": ["begin"] },
      { "active": ["check"], "edges": [0] },
      { "active": ["cond"], "edges": [1] },
      { "active": ["apply"], "edges": [2] },
      { "active": ["commit"], "edges": [3] },
      { "active": ["cond"] },
      { "active": ["rollback"], "edges": [4] }
    ]
  }
}
