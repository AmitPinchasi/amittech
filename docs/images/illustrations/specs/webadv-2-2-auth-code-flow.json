{
  "title": "זרימת Authorization Code ב-OAuth 2.0: המשתמש מאשר אצל שרת ההרשאה, האפליקציה מקבלת code ומחליפה אותו בטוקן בבקשת צד-שרת",
  "layout": { "type": "flow" },
  "components": [
    { "id": "u1", "type": "box", "label": "המשתמש בוחר להתחבר עם ספק חיצוני" },
    { "id": "a1", "type": "box", "label": "הפניה לשרת ההרשאה עם client_id ו-state" },
    { "id": "u2", "type": "box", "label": "המשתמש מתחבר ומאשר הרשאות" },
    { "id": "a2", "type": "box", "label": "שרת ההרשאה מחזיר authorization code" },
    { "id": "ex", "type": "code", "lines": ["POST /token", "code + client_secret"] },
    { "id": "tok", "type": "box", "label": "האפליקציה מקבלת access token" },
    { "id": "res", "type": "box", "label": "גישה למשאבי המשתמש עם הטוקן" }
  ],
  "connections": [
    { "from": "u1", "to": "a1" },
    { "from": "a1", "to": "u2" },
    { "from": "u2", "to": "a2" },
    { "from": "a2", "to": "ex", "label": "החלפת קוד בבקשת צד-שרת" },
    { "from": "ex", "to": "tok" },
    { "from": "tok", "to": "res" }
  ],
  "animation": {
    "step_seconds": 1.6,
    "steps": [
      { "active": ["u1"] },
      { "active": ["a1"], "edges": [0] },
      { "active": ["u2"], "edges": [1] },
      { "active": ["a2"], "edges": [2] },
      { "active": ["ex"], "edges": [3] },
      { "active": ["tok"], "edges": [4] },
      { "active": ["res"], "edges": [5] }
    ]
  }
}
