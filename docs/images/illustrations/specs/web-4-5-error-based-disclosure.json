{
  "title": "תרשים זרימה של Error-Based SQLi: קלט זדוני גורם לשגיאת SQL שעלולה לחשוף מידע פנימי, וטיפול נכון בשגיאות מציג הודעה גנרית למשתמש בעוד הפרטים נרשמים רק ביומן השרת",
  "layout": { "type": "flow" },
  "components": [
    { "id": "input", "type": "box", "label": "קלט משתמש לא מסונן ב-id" },
    { "id": "query", "type": "code", "lines": ["SELECT username FROM users", "WHERE id = '$id'"] },
    { "id": "dbError", "type": "box", "label": "מסד הנתונים מחזיר שגיאת SQL" },
    { "id": "handle", "type": "diamond", "label": "השגיאה מטופלת כראוי?" },
    { "id": "leak", "type": "box", "label": "השגיאה המלאה מוצגת למשתמש" },
    { "id": "info", "type": "box", "label": "התוקף לומד גרסת DB ומבנה טבלאות" },
    { "id": "generic", "type": "box", "label": "הודעה גנרית - פרטים רק ב-log" }
  ],
  "connections": [
    { "from": "input", "to": "query" },
    { "from": "query", "to": "dbError" },
    { "from": "dbError", "to": "handle" },
    { "from": "handle", "to": "leak", "label": "לא" },
    { "from": "leak", "to": "info" },
    { "from": "handle", "to": "generic", "label": "כן", "side": "right" }
  ],
  "animation": {
    "step_seconds": 1.6,
    "steps": [
      { "active": ["input"] },
      { "active": ["query"], "edges": [0] },
      { "active": ["dbError"], "edges": [1] },
      { "active": ["handle"], "edges": [2] },
      { "active": ["generic"], "edges": [5] },
      { "active": ["handle"] },
      { "active": ["leak"], "edges": [3] },
      { "active": ["info"], "edges": [4] }
    ]
  }
}
