{
  "title": "מסלול מלא של Server Action משליחת הטופס בדפדפן ועד רענון הקאש והצגת הנתונים החדשים",
  "layout": { "type": "flow" },
  "components": [
    { "id": "form", "type": "box", "label": "המשתמש שולח את הטופס בדפדפן" },
    { "id": "send", "type": "box", "label": "נקסט שולח את ה-FormData לשרת" },
    { "id": "act", "type": "box", "label": "createPost רץ בשרת" },
    { "id": "db", "type": "box", "label": "prisma יוצר רשומה בבסיס הנתונים" },
    { "id": "reval", "type": "box", "label": "revalidatePath מבטל את הקאש של הנתיב" },
    { "id": "html", "type": "box", "label": "הדף המעודכן חוזר לדפדפן" },
    { "id": "list", "type": "dynamic",
      "values": ["רשימת הפוסטים: 3 פוסטים", "רשימת הפוסטים: 4 פוסטים"] }
  ],
  "connections": [
    { "from": "form", "to": "send" },
    { "from": "send", "to": "act" },
    { "from": "act", "to": "db" },
    { "from": "db", "to": "reval" },
    { "from": "reval", "to": "html" },
    { "from": "html", "to": "list" }
  ],
  "animation": {
    "step_seconds": 1.8,
    "steps": [
      { "active": ["form"], "set": { "list": 0 } },
      { "active": ["send"], "edges": [0] },
      { "active": ["act"], "edges": [1] },
      { "active": ["db"], "edges": [2] },
      { "active": ["reval"], "edges": [3] },
      { "active": ["html"], "edges": [4] },
      { "active": ["list"], "set": { "list": 1 }, "edges": [5] }
    ]
  }
}
