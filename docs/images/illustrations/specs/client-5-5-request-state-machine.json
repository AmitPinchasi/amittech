{
  "title": "מכונת מצבים של בקשת רשת עם discriminated union: כל מצב מכיל רק את השדות שלו",
  "layout": { "type": "flow" },
  "components": [
    { "id": "idle", "type": "code", "label": "{ status: \"idle\" }" },
    { "id": "loading", "type": "code", "label": "{ status: \"loading\", startedAt }" },
    { "id": "cond", "type": "diamond", "label": "הבקשה הצליחה?" },
    { "id": "success", "type": "code", "label": "{ status: \"success\", data }" },
    { "id": "error", "type": "code", "label": "{ status: \"error\", error, retryCount }" },
    { "id": "ui", "type": "box", "label": "רינדור לפי status" }
  ],
  "connections": [
    { "from": "idle", "to": "loading", "label": "start" },
    { "from": "loading", "to": "cond" },
    { "from": "cond", "to": "success", "label": "כן", "side": "right" },
    { "from": "cond", "to": "error", "label": "לא", "side": "left" },
    { "from": "success", "to": "ui" },
    { "from": "error", "to": "ui" },
    { "from": "ui", "to": "idle", "label": "reset", "loop": true }
  ],
  "animation": {
    "step_seconds": 1.7,
    "steps": [
      { "active": ["idle"] },
      { "active": ["loading"], "edges": [0] },
      { "active": ["cond"], "edges": [1] },
      { "active": ["success"], "edges": [2] },
      { "active": ["ui"], "edges": [4] },
      { "active": ["idle"], "edges": [6] },
      { "active": ["loading"], "edges": [0] },
      { "active": ["cond"], "edges": [1] },
      { "active": ["error"], "edges": [3] },
      { "active": ["ui"], "edges": [5] }
    ]
  }
}
