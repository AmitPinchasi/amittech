{
  "title": "מסע פאקטה דרך שרשראות ה-netfilter בלינוקס: אחרי PREROUTING מתקבלת החלטת ניתוב, פאקטה ליעד מקומי עוברת ל-INPUT ואילו פאקטה שממשיכה הלאה עוברת ל-FORWARD ואז ל-POSTROUTING ביציאה",
  "layout": { "type": "flow" },
  "components": [
    { "id": "in", "type": "box", "label": "פאקטה נכנסת" },
    { "id": "pre", "type": "box", "label": "PREROUTING" },
    { "id": "route", "type": "diamond", "label": "היעד הוא המחשב?" },
    { "id": "input", "type": "box", "label": "INPUT" },
    { "id": "fwd", "type": "box", "label": "FORWARD" },
    { "id": "post", "type": "box", "label": "POSTROUTING" },
    { "id": "out", "type": "box", "label": "פאקטה יוצאת" }
  ],
  "connections": [
    { "from": "in", "to": "pre" },
    { "from": "pre", "to": "route" },
    { "from": "route", "to": "input", "side": "right", "label": "כן" },
    { "from": "route", "to": "fwd", "label": "לא" },
    { "from": "fwd", "to": "post" },
    { "from": "post", "to": "out" }
  ],
  "animation": {
    "step_seconds": 1.8,
    "steps": [
      { "active": ["in"] },
      { "active": ["pre"], "edges": [0] },
      { "active": ["route"], "edges": [1] },
      { "active": ["fwd"], "edges": [3] },
      { "active": ["post"], "edges": [4] },
      { "active": ["out"], "edges": [5] }
    ]
  }
}
