{
  "title": "זרימת עבודה עם git מול agent: פותחים branch ייעודי, עובדים, בוחרים אילו קבצים נכנסים לstaging, סוקרים diff ומחפשים secrets, ורק אחרי אישור מפורש עושים commit ודוחפים לPR",
  "layout": { "type": "flow" },
  "components": [
    { "id": "branch", "type": "box", "label": "פתיחת branch ייעודי" },
    { "id": "work", "type": "box", "label": "עבודה על הפיצ'ר" },
    { "id": "stage", "type": "box", "label": "בחירת קבצים לstaging" },
    { "id": "diff", "type": "box", "label": "סקירת diff וחיפוש secrets" },
    { "id": "gate", "type": "diamond", "label": "אישרתם?" },
    { "id": "commit", "type": "box", "label": "הודעת commit - למה השתנה" },
    { "id": "push", "type": "box", "label": "דחיפה ופתיחת PR" }
  ],
  "connections": [
    { "from": "branch", "to": "work" },
    { "from": "work", "to": "stage" },
    { "from": "stage", "to": "diff" },
    { "from": "diff", "to": "gate" },
    { "from": "gate", "to": "stage", "label": "לא - עדיין לא", "loop": true },
    { "from": "gate", "to": "commit", "label": "כן" },
    { "from": "commit", "to": "push" }
  ],
  "animation": {
    "step_seconds": 1.6,
    "steps": [
      { "active": ["branch"] },
      { "active": ["work"], "edges": [0] },
      { "active": ["stage"], "edges": [1] },
      { "active": ["diff"], "edges": [2] },
      { "active": ["gate"], "edges": [3] },
      { "active": ["stage"], "edges": [4] },
      { "active": ["diff"], "edges": [2] },
      { "active": ["gate"], "edges": [3] },
      { "active": ["commit"], "edges": [5] },
      { "active": ["push"], "edges": [6] }
    ]
  }
}
