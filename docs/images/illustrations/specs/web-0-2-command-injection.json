{
  "title": "הדגמת command injection: קלט המשתמש document1; ls מוזרק לתוך פקודת cat, והנקודה-פסיק גורמת לשרת להריץ גם את הפקודה ls שהוזרקה",
  "layout": { "type": "flow" },
  "components": [
    { "id": "field", "type": "box", "label": "שדה קלט filename" },
    { "id": "cmd", "type": "code", "values": ["cat {filename}", "cat document1; ls"] },
    { "id": "shell", "type": "box", "label": "השרת מריץ את הפקודה בטרמינל" },
    { "id": "c1", "type": "box", "label": "cat document1 - קורא את הקובץ" },
    { "id": "c2", "type": "box", "label": "ls - הפקודה שהוזרקה רצה" }
  ],
  "connections": [
    { "from": "field", "to": "cmd", "label": "מזין document1; ls" },
    { "from": "cmd", "to": "shell" },
    { "from": "shell", "to": "c1" },
    { "from": "c1", "to": "c2", "label": "אחרי ;" }
  ],
  "animation": {
    "step_seconds": 1.8,
    "steps": [
      { "active": ["field"], "set": { "cmd": 0 } },
      { "active": ["cmd"], "edges": [0], "set": { "cmd": 1 } },
      { "active": ["shell"], "edges": [1] },
      { "active": ["c1"], "edges": [2] },
      { "active": ["c2"], "edges": [3] }
    ]
  }
}
