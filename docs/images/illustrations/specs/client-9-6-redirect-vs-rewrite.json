{
  "title": "ההבדל בין redirect לבין rewrite במידלוור וההשפעה על הכתובת שמוצגת בדפדפן",
  "layout": { "type": "flow" },
  "components": [
    { "id": "req", "type": "box", "label": "בקשה לכתובת api/v1/users" },
    { "id": "cond", "type": "diamond", "label": "מה המידלוור מחזיר?",
      "values": ["מה המידלוור מחזיר?", "NextResponse.redirect", "NextResponse.rewrite"] },
    { "id": "rew", "type": "box", "label": "השרת מגיש נתיב אחר באותה בקשה" },
    { "id": "red", "type": "box", "label": "הדפדפן מקבל 307 ופונה שוב לכתובת החדשה" },
    { "id": "bar", "type": "dynamic",
      "values": ["בשורת הכתובת מוצג api/users", "בשורת הכתובת נשאר api/v1/users"] }
  ],
  "connections": [
    { "from": "req", "to": "cond" },
    { "from": "cond", "to": "red", "label": "redirect" },
    { "from": "red", "to": "bar" },
    { "from": "cond", "to": "rew", "label": "rewrite", "side": "right" },
    { "from": "rew", "to": "bar" }
  ],
  "animation": {
    "step_seconds": 1.8,
    "steps": [
      { "active": ["req"] },
      { "active": ["cond"], "set": { "cond": 1 }, "edges": [0] },
      { "active": ["red"], "edges": [1] },
      { "active": ["bar"], "set": { "bar": 0 }, "edges": [2] },
      { "active": ["req"] },
      { "active": ["cond"], "set": { "cond": 2 }, "edges": [0] },
      { "active": ["rew"], "edges": [3] },
      { "active": ["bar"], "set": { "bar": 1 }, "edges": [4] }
    ]
  }
}
