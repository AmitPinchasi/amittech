{
  "title": "סדר הרינדור של נתיב בנקסט מהלייאאוט דרך מסך הטעינה ועד הדף או מסך השגיאה",
  "layout": { "type": "flow" },
  "components": [
    { "id": "req", "type": "box", "label": "בקשה לנתיב blog" },
    { "id": "layout", "type": "box", "label": "layout.tsx מרונדר ראשון" },
    { "id": "loading", "type": "box", "label": "loading.tsx מוצג בזמן שליפת הנתונים" },
    { "id": "cond", "type": "diamond", "label": "הרינדור הצליח?",
      "values": ["הרינדור הצליח?", "לא - נזרקה שגיאה", "כן - הנתונים הגיעו"] },
    { "id": "err", "type": "box", "label": "error.tsx תופס את השגיאה" },
    { "id": "page", "type": "box", "label": "page.tsx מוצג עם הנתונים" }
  ],
  "connections": [
    { "from": "req", "to": "layout" },
    { "from": "layout", "to": "loading" },
    { "from": "loading", "to": "cond" },
    { "from": "cond", "to": "page", "label": "כן" },
    { "from": "cond", "to": "err", "label": "לא", "side": "right" }
  ],
  "animation": {
    "step_seconds": 1.8,
    "steps": [
      { "active": ["req"] },
      { "active": ["layout"], "edges": [0] },
      { "active": ["loading"], "edges": [1] },
      { "active": ["cond"], "set": { "cond": 1 }, "edges": [2] },
      { "active": ["err"], "edges": [4] },
      { "active": ["loading"] },
      { "active": ["cond"], "set": { "cond": 2 }, "edges": [2] },
      { "active": ["page"], "edges": [3] }
    ]
  }
}
